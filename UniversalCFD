UPDATED_SCRIPT_NAME = "ahmed_body_cfd_actual_benchmark_frontal_combined.py"


def is_readable_file(path: str) -> bool:
    """Return True only when the path exists and can be opened."""
    try:
        if not os.path.isfile(path):
            return False
        with open(path, "rb") as f:
            f.read(1)
        return True
    except OSError:
        return False


def resolve_obj_path(file_name: str, export_dir: str) -> str | None:
    """Locate AhmedGeometry.obj in internal Download/AhmedGeometry or nearby folders.

    This is designed for Android internal storage:
        /storage/emulated/0/Download/AhmedGeometry/AhmedGeometry.obj

    It also checks the current working directory and the export directory so the
    same script works on desktop Python and in this sandbox.
    """
    candidates = []

    if os.path.isabs(file_name):
        candidates.append(file_name)
    else:
        script_dir = os.path.dirname(os.path.abspath(__file__)) if "__file__" in globals() else os.getcwd()
        candidates.extend([
            os.path.join(export_dir, file_name),
            os.path.join(INTERNAL_AHMED_DIR, file_name),
            os.path.join("/sdcard/Download/AhmedGeometry", file_name),
            os.path.join(os.getcwd(), file_name),
            os.path.join(script_dir, file_name),
            os.path.join("/storage/emulated/0/Download", file_name),
            os.path.join("/sdcard/Download", file_name),
        ])

    seen = set()
    cprint("[I/O] Searching for Ahmed OBJ geometry file...")
    for candidate in candidates:
        candidate = os.path.abspath(os.path.expanduser(candidate))
        if candidate in seen:
            continue
        seen.add(candidate)
        cprint(f"[I/O] Checking OBJ path: {candidate}")
        if is_readable_file(candidate):
            cprint(f"[I/O] Located readable OBJ: {candidate}")
            return candidate
        if os.path.exists(candidate):
            cprint(f"[I/O] Found OBJ path but cannot read it due to permissions: {candidate}")

    cprint("[I/O] No readable AhmedGeometry.obj found. The script will generate an analytic 25-degree Ahmed body.")
    return None


def mirror_current_script_to_export_dir(export_dir: str) -> str | None:
    """Copy the running Python file into the AhmedGeometry output folder."""
    try:
        source = os.path.abspath(__file__)
    except NameError:
        cprint("[I/O] __file__ is not available; cannot mirror the Python script.")
        return None

    try:
        destination = os.path.join(export_dir, UPDATED_SCRIPT_NAME)
        if os.path.abspath(source) != os.path.abspath(destination):
            shutil.copy2(source, destination)
        cprint(f"[I/O] Python script available at: {destination}")
        return destination
    except OSError as exc:
        cprint(f"[I/O] Could not copy Python script into output folder: {exc}")
        return None


def interpretation_rating(value: float, good: float, acceptable: float) -> str:
    """Small helper for residual/y+ coefficient text."""
    if value <= good:
        return "good"
    if value <= acceptable:
        return "acceptable"
    return "coarse / needs refinement"


@dataclass
class AhmedBodyParameters:
    length: float = 1.044
    width: float = 0.389
    height: float = 0.288
    ground_clearance: float = 0.050
    slant_angle_deg: float = 25.0
    slant_length: float = 0.222
    front_radius: float = 0.100

    @property
    def frontal_area(self) -> float:
        return self.width * self.height

    @property
    def slant_angle_rad(self) -> float:
        return math.radians(self.slant_angle_deg)

    @property
    def slant_projected_length(self) -> float:
        return self.slant_length * math.cos(self.slant_angle_rad)

    @property
    def slant_vertical_drop(self) -> float:
        return self.slant_length * math.sin(self.slant_angle_rad)

    @property
    def x_slant_start(self) -> float:
        return self.length - self.slant_projected_length

    @property
    def z_bottom(self) -> float:
        return self.ground_clearance

    @property
    def z_top(self) -> float:
        return self.ground_clearance + self.height

    @property
    def z_rear_top(self) -> float:
        return self.z_top - self.slant_vertical_drop

    def top_z(self, x: np.ndarray | float) -> np.ndarray | float:
        x_arr = np.asarray(x)
        z = np.full_like(x_arr, self.z_top, dtype=float)
        mask = x_arr > self.x_slant_start
        z[mask] = self.z_top - (x_arr[mask] - self.x_slant_start) * math.tan(self.slant_angle_rad)
        z = np.maximum(z, self.z_rear_top)
        if np.isscalar(x):
            return float(z)
        return z


class ActualAhmedGeometry:
    """Triangulated actual Ahmed body with 25-degree rear slant."""

    def __init__(self, params: AhmedBodyParameters, nx: int = 48, ny: int = 18, nz: int = 18):
        self.params = params
        self.nx = int(nx)
        self.ny = int(ny)
        self.nz = int(nz)
        self.vertices: np.ndarray | None = None
        self.faces: np.ndarray | None = None
        self.face_normals: np.ndarray | None = None
        self.face_centroids: np.ndarray | None = None
        self.vertex_normals: np.ndarray | None = None
        self.face_areas: np.ndarray | None = None
        self.baseline_vertices: np.ndarray | None = None
        self.morphed_alpha: float = 0.0
        self.source_obj_path: str | None = None

    def add_grid_surface(self, vertices: List[List[float]], faces: List[List[int]], grid: np.ndarray, flip: bool = False) -> None:
        """Append a structured MxN grid surface and triangulate it."""
        base = len(vertices)
        m, n, _ = grid.shape
        vertices.extend(grid.reshape(-1, 3).tolist())
        for i in range(m - 1):
            for j in range(n - 1):
                a = base + i * n + j
                b = base + (i + 1) * n + j
                c = base + (i + 1) * n + (j + 1)
                d = base + i * n + (j + 1)
                if not flip:
                    faces.append([a, b, c])
                    faces.append([a, c, d])
                else:
                    faces.append([a, c, b])
                    faces.append([a, d, c])

    def load_obj(self, obj_path: str, normalize_to_standard: bool = True) -> None:
        """Load a user-provided OBJ and normalize it to actual Ahmed-body axes.

        Many STL-to-OBJ Ahmed bodies use length along Y and width along X.
        This loader detects the longest axis as vehicle length, uses OBJ Z as
        vertical when possible, and maps the body into:
            x = 0..L,
            y = -W/2..W/2,
            z = clearance..clearance+H.
        """
        raw_vertices: List[List[float]] = []
        raw_faces: List[List[int]] = []

        with open(obj_path, "r", encoding="utf-8", errors="ignore") as obj_file:
            for line in obj_file:
                line = line.strip()
                if line.startswith("v "):
                    parts = line.split()[1:4]
                    if len(parts) == 3:
                        raw_vertices.append([float(parts[0]), float(parts[1]), float(parts[2])])
                elif line.startswith("f "):
                    tokens = line.split()[1:]
                    indices = []
                    for token in tokens:
                        index_text = token.split("/")[0]
                        if not index_text:
                            continue
                        index = int(index_text)
                        if index < 0:
                            index = len(raw_vertices) + index
                        else:
                            index = index - 1
                        indices.append(index)
                    if len(indices) >= 3:
                        for j in range(1, len(indices) - 1):
                            raw_faces.append([indices[0], indices[j], indices[j + 1]])

        if not raw_vertices or not raw_faces:
            raise ValueError(f"OBJ had no usable vertices/faces: {obj_path}")

        vertices = np.asarray(raw_vertices, dtype=float)
        faces = np.asarray(raw_faces, dtype=int)

        if normalize_to_standard:
            p = self.params
            lo = vertices.min(axis=0)
            hi = vertices.max(axis=0)
            ext = hi - lo

            long_axis = int(np.argmax(ext))
            vertical_axis = 2 if ext[2] > 1.0e-12 and long_axis != 2 else int(np.argsort(ext)[-2])
            lateral_axis = [axis for axis in range(3) if axis not in (long_axis, vertical_axis)][0]

            x_old = vertices[:, long_axis]
            y_old = vertices[:, lateral_axis]
            z_old = vertices[:, vertical_axis]

            x_new = (x_old - x_old.min()) / max(x_old.max() - x_old.min(), 1e-12) * p.length
            y_new = (y_old - 0.5 * (y_old.min() + y_old.max())) / max(y_old.max() - y_old.min(), 1e-12) * p.width
            z_new = (z_old - z_old.min()) / max(z_old.max() - z_old.min(), 1e-12) * p.height + p.ground_clearance

            vertices = np.column_stack([x_new, y_new, z_new])

            cprint("[GEOMETRY] Loaded OBJ was normalized to standard Ahmed dimensions.")
            cprint(f"[GEOMETRY] Axis map: old axis {long_axis}->x length, old axis {lateral_axis}->y width, old axis {vertical_axis}->z height.")
        else:
            cprint("[GEOMETRY] Loaded OBJ without normalization.")

        self.vertices = vertices
        self.faces = faces
        self.baseline_vertices = self.vertices.copy()
        self.source_obj_path = obj_path
        self.compute_normals_and_areas()

        bbox_lo = self.vertices.min(axis=0)
        bbox_hi = self.vertices.max(axis=0)
        bbox_dim = bbox_hi - bbox_lo
        cprint(f"[GEOMETRY] OBJ loaded: {len(self.vertices):,} vertices, {len(self.faces):,} triangular faces")
        cprint(f"[GEOMETRY] Normalized bounding box dimensions: L={bbox_dim[0]:.6f} m, W={bbox_dim[1]:.6f} m, H={bbox_dim[2]:.6f} m")
        cprint(f"[GEOMETRY] Source OBJ: {obj_path}")

    def build_mesh(self) -> None:
        p = self.params
        vertices: List[List[float]] = []
        faces: List[List[int]] = []

        x = np.linspace(0.0, p.length, self.nx)
        y = np.linspace(-p.width / 2.0, p.width / 2.0, self.ny)
        z_top_x = p.top_z(x)

        # Bottom surface, z = clearance.
        X, Y = np.meshgrid(x, y, indexing="ij")
        Z = np.full_like(X, p.z_bottom)
        self.add_grid_surface(vertices, faces, np.dstack([X, Y, Z]), flip=True)

        # Top + slanted rear surface, z = top_z(x).
        Z = np.repeat(z_top_x[:, None], self.ny, axis=1)
        self.add_grid_surface(vertices, faces, np.dstack([X, Y, Z]), flip=False)

        # Left and right side surfaces with variable top_z(x).
        z_frac = np.linspace(0.0, 1.0, self.nz)
        Xs, Fs = np.meshgrid(x, z_frac, indexing="ij")
        Zs = p.z_bottom + Fs * (p.top_z(Xs) - p.z_bottom)
        Y_left = np.full_like(Xs, -p.width / 2.0)
        Y_right = np.full_like(Xs, p.width / 2.0)
        self.add_grid_surface(vertices, faces, np.dstack([Xs, Y_left, Zs]), flip=True)
        self.add_grid_surface(vertices, faces, np.dstack([Xs, Y_right, Zs]), flip=False)

        # Front face x = 0.
        yf, zf = np.meshgrid(y, np.linspace(p.z_bottom, p.z_top, self.nz), indexing="ij")
        xf = np.zeros_like(yf)
        self.add_grid_surface(vertices, faces, np.dstack([xf, yf, zf]), flip=True)

        # Rear vertical base face x = L, top height = z_rear_top.
        yr, zr = np.meshgrid(y, np.linspace(p.z_bottom, p.z_rear_top, self.nz), indexing="ij")
        xr = np.full_like(yr, p.length)
        self.add_grid_surface(vertices, faces, np.dstack([xr, yr, zr]), flip=False)

        self.vertices = np.asarray(vertices, dtype=float)
        self.faces = np.asarray(faces, dtype=int)
        self.baseline_vertices = self.vertices.copy()
        self.compute_normals_and_areas()
        cprint(f"[GEOMETRY] Actual Ahmed mesh created: {len(self.vertices):,} vertices, {len(self.faces):,} triangular faces")

    def compute_normals_and_areas(self) -> None:
        """Compute oriented triangle normals, centroids, and areas.

        The OBJ supplied by a CAD/export tool may not have consistent winding.
        For coefficient integration, normals must point approximately outward.
        This routine flips each face normal when it points toward the body center.
        """
        assert self.vertices is not None and self.faces is not None
        v0 = self.vertices[self.faces[:, 0]]
        v1 = self.vertices[self.faces[:, 1]]
        v2 = self.vertices[self.faces[:, 2]]
        cross = np.cross(v1 - v0, v2 - v0)
        dbl_area = np.linalg.norm(cross, axis=1)
        self.face_areas = 0.5 * dbl_area
        raw_normals = np.divide(cross, dbl_area[:, None] + 1e-14)
        self.face_centroids = (v0 + v1 + v2) / 3.0

        center = 0.5 * (self.vertices.min(axis=0) + self.vertices.max(axis=0))
        outward_test = np.einsum("ij,ij->i", raw_normals, self.face_centroids - center)
        raw_normals[outward_test < 0.0] *= -1.0
        self.face_normals = raw_normals

        self.vertex_normals = np.zeros_like(self.vertices)
        for k in range(3):
            np.add.at(self.vertex_normals, self.faces[:, k], self.face_normals)
        nrm = np.linalg.norm(self.vertex_normals, axis=1, keepdims=True)
        self.vertex_normals = np.divide(self.vertex_normals, nrm + 1e-14)

    def morph_geometry(self, alpha: float) -> float:
        """Normal-driven Harding morphing. alpha=0 preserves actual Ahmed body."""
        assert self.vertices is not None and self.vertex_normals is not None and self.face_areas is not None
        self.morphed_alpha = float(alpha)
        if abs(alpha) <= 0.0:
            return 0.0
        reference_volume = self.bounding_box_volume()
        self.vertices = self.vertices + alpha * self.vertex_normals
        self.compute_normals_and_areas()
        volume_change_pct = 100.0 * (self.bounding_box_volume() - reference_volume) / max(reference_volume, 1e-14)
        return float(volume_change_pct)

    def swept_volume_estimate(self) -> float:
        """Harding swept-volume estimate sum_i A_i (Delta x_i dot n_i)."""
        assert self.face_areas is not None
        return float(abs(self.morphed_alpha) * np.sum(self.face_areas))

    def bounding_box_volume(self) -> float:
        assert self.vertices is not None
        lo = self.vertices.min(axis=0)
        hi = self.vertices.max(axis=0)
        return float(np.prod(hi - lo))

    def total_surface_area(self) -> float:
        assert self.face_areas is not None
        return float(np.sum(self.face_areas))

    def bounding_box_dimensions(self) -> np.ndarray:
        """Return actual mesh bounding-box dimensions in x, y, z after normalization."""
        assert self.vertices is not None
        lo = self.vertices.min(axis=0)
        hi = self.vertices.max(axis=0)
        return hi - lo

    def bbox_frontal_projected_area(self) -> float:
        """Benchmark frontal projection area from the normalized y-z silhouette.

        Ahmed-body drag coefficients conventionally use the projected frontal
        area normal to the flow direction, not the wetted surface area. For the
        standard geometry this is W*H = 0.389*0.288 = 0.112032 m^2.
        """
        dims = self.bounding_box_dimensions()
        return float(dims[1] * dims[2])

    def front_surface_projected_area_diagnostic(self) -> float:
        """Approximate projected area of front-facing mesh triangles.

        This is only a diagnostic because rounded/CAD front surfaces can split
        the visible silhouette across curved panels. The benchmark reference
        area remains W*H; this number is printed so the user can inspect whether
        the OBJ front face is consistent with the normalized silhouette.
        """
        assert self.face_normals is not None
        assert self.face_centroids is not None
        assert self.face_areas is not None
        assert self.vertices is not None
        p = self.params
        x_min = float(self.vertices[:, 0].min())
        front_zone = self.face_centroids[:, 0] <= x_min + 0.08 * p.length
        faces_into_flow = self.face_normals[:, 0] < -0.10
        mask = front_zone & faces_into_flow
        if not np.any(mask):
            return 0.0
        return float(np.sum(np.abs(self.face_normals[mask, 0]) * self.face_areas[mask]))

    def export_obj(self, path: str) -> None:
        assert self.vertices is not None and self.faces is not None
        with open(path, "w", encoding="utf-8") as f:
            f.write("# Actual 25-degree Ahmed body generated by ahmed_body_cfd_actual.py\n")
            p = self.params
            f.write(f"# L={p.length} W={p.width} H={p.height} clearance={p.ground_clearance} slant={p.slant_angle_deg}\n")
            for v in self.vertices:
                f.write(f"v {v[0]:.9f} {v[1]:.9f} {v[2]:.9f}\n")
            for tri in self.faces:
                f.write(f"f {tri[0]+1} {tri[1]+1} {tri[2]+1}\n")
        cprint(f"[EXPORT] OBJ saved: {path}")


class AhmedVoxelCFDDiagnostic:
    """Reduced-order voxel CFD diagnostics around the actual Ahmed geometry."""

    def __init__(self, geometry: ActualAhmedGeometry, u_inf: float = 40.0, grid_shape: Tuple[int, int, int] = (112, 56, 56)):
        self.geometry = geometry
        self.params = geometry.params
        self.u_inf = float(u_inf)
        self.grid_shape = tuple(int(x) for x in grid_shape)
        self.rho = 1.225
        self.mu = 1.81e-5
        self.nu = self.mu / self.rho
        self.q_inf = 0.5 * self.rho * self.u_inf**2
        self.ref_area = self.params.frontal_area
        self.reynolds_length = self.rho * self.u_inf * self.params.length / self.mu
        self.benchmark_cd_25 = 0.285
        self.time_history: Dict[str, List[float]] = {
            "iteration": [], "cd": [], "cl": [], "res_continuity": [], "res_momentum": [], "res_pressure": []
        }
        self.voxel: Dict[str, np.ndarray] = {}
        self.scalar_results: Dict[str, float] = {}

    @staticmethod
    def coefficient_from_force(force_newtons: float, dynamic_pressure_pa: float, reference_area_m2: float) -> float:
        """Generic aerodynamic coefficient formula: C = F / (q_inf A_ref)."""
        return float(force_newtons / max(dynamic_pressure_pa * reference_area_m2, 1.0e-30))

    @staticmethod
    def force_from_coefficient(coefficient: float, dynamic_pressure_pa: float, reference_area_m2: float) -> float:
        """Inverse formula: F = C q_inf A_ref."""
        return float(coefficient * dynamic_pressure_pa * reference_area_m2)

    def drag_coefficient_from_force(self, drag_force_newtons: float) -> float:
        """Ahmed body drag coefficient using the usual frontal reference area A_ref = W H."""
        return self.coefficient_from_force(drag_force_newtons, self.q_inf, self.ref_area)

    def lift_coefficient_from_force(self, lift_force_newtons: float) -> float:
        """Ahmed body lift coefficient using the same reference area A_ref = W H.

        Sign convention: +CL is upward lift; -CL is downforce.
        """
        return self.coefficient_from_force(lift_force_newtons, self.q_inf, self.ref_area)

    def estimate_local_surface_cp(self, centroid: np.ndarray, normal: np.ndarray) -> float:
        """Approximate pressure coefficient on Ahmed-body surfaces.

        This is a geometry-based diagnostic pressure model, not a solved RANS
        pressure field. It gives a force-integrated CD/CL estimate that follows
        the usual 25-degree Ahmed configuration: front stagnation, underbody
        suction, roof/slant suction, side weak suction, and rear base pressure
        deficit.
        """
        p = self.params
        x, y, z = [float(v) for v in centroid]
        nx, ny, nz = [float(v) for v in normal]
        eps_x = 0.035 * p.length
        eps_z = 0.035 * p.height

        # Front stagnation face.
        if x <= eps_x and nx < -0.35:
            return 0.78

        # Rear vertical base: low base pressure causes pressure drag.
        if x >= p.length - eps_x and nx > 0.35:
            return -0.34

        # Underbody: accelerated ground-effect channel gives suction/downforce.
        if z <= p.z_bottom + eps_z and nz < -0.35:
            clearance_ratio = 0.050 / max(p.ground_clearance, 0.008)
            return float(1.0 - clearance_ratio)  # 0 at 50 mm; negative for tighter clearance.

        # Upper rear slant: separation/suction over the 25 degree slanted deck.
        if x >= p.x_slant_start - eps_x and nz > 0.25:
            return -0.22

        # Roof suction and side weak suction.
        if nz > 0.45:
            return -0.08
        if abs(ny) > 0.45:
            return -0.04

        return 0.0

    def compute_frontal_benchmark_criteria(self, tolerance_pct: float = 0.50) -> Dict[str, float | bool]:
        """Check that the geometry meets the usual Ahmed-body frontal benchmark.

        Criteria tested here:
          * L = 1.044 m, W = 0.389 m, H = 0.288 m after normalization.
          * A_ref = W*H = 0.112032 m^2, commonly reported as 0.112 m^2.
          * CD and CL use the same frontal projected area A_ref, not surface area.
          * The bounding-box y-z projection matches the intended A_ref.
        """
        p = self.params
        dims = self.geometry.bounding_box_dimensions()
        length_actual, width_actual, height_actual = [float(v) for v in dims]

        exact_frontal_area = p.width * p.height
        reported_frontal_area = 0.112
        bbox_frontal_area = self.geometry.bbox_frontal_projected_area()
        front_panel_projected_area = self.geometry.front_surface_projected_area_diagnostic()

        def pct_error(actual: float, target: float) -> float:
            return 100.0 * (actual - target) / max(abs(target), 1.0e-30)

        checks = {
            "benchmark_length_error_pct": pct_error(length_actual, p.length),
            "benchmark_width_error_pct": pct_error(width_actual, p.width),
            "benchmark_height_error_pct": pct_error(height_actual, p.height),
            "benchmark_frontal_area_exact_error_pct": pct_error(self.ref_area, exact_frontal_area),
            "benchmark_frontal_area_reported_error_pct": pct_error(self.ref_area, reported_frontal_area),
            "benchmark_bbox_frontal_area_error_pct": pct_error(bbox_frontal_area, exact_frontal_area),
            "benchmark_slant_angle_error_deg": p.slant_angle_deg - 25.0,
            "benchmark_clearance_error_pct": pct_error(p.ground_clearance, 0.050),
        }

        pass_length = abs(checks["benchmark_length_error_pct"]) <= tolerance_pct
        pass_width = abs(checks["benchmark_width_error_pct"]) <= tolerance_pct
        pass_height = abs(checks["benchmark_height_error_pct"]) <= tolerance_pct
        pass_exact_area = abs(checks["benchmark_frontal_area_exact_error_pct"]) <= tolerance_pct
        pass_reported_area = abs(checks["benchmark_frontal_area_reported_error_pct"]) <= tolerance_pct
        pass_bbox_area = abs(checks["benchmark_bbox_frontal_area_error_pct"]) <= tolerance_pct
        pass_slant = abs(checks["benchmark_slant_angle_error_deg"]) <= 0.50
        pass_clearance = abs(checks["benchmark_clearance_error_pct"]) <= tolerance_pct
        overall_pass = all([
            pass_length, pass_width, pass_height, pass_exact_area,
            pass_reported_area, pass_bbox_area, pass_slant, pass_clearance,
        ])

        results: Dict[str, float | bool] = {
            "benchmark_length_target_m": float(p.length),
            "benchmark_width_target_m": float(p.width),
            "benchmark_height_target_m": float(p.height),
            "benchmark_length_actual_m": length_actual,
            "benchmark_width_actual_m": width_actual,
            "benchmark_height_actual_m": height_actual,
            "benchmark_frontal_area_exact_m2": float(exact_frontal_area),
            "benchmark_frontal_area_reported_m2": float(reported_frontal_area),
            "benchmark_frontal_area_used_m2": float(self.ref_area),
            "benchmark_bbox_frontal_area_m2": float(bbox_frontal_area),
            "benchmark_front_panel_projected_area_diagnostic_m2": float(front_panel_projected_area),
            "benchmark_tolerance_pct": float(tolerance_pct),
            "benchmark_length_pass": bool(pass_length),
            "benchmark_width_pass": bool(pass_width),
            "benchmark_height_pass": bool(pass_height),
            "benchmark_frontal_area_exact_pass": bool(pass_exact_area),
            "benchmark_frontal_area_reported_pass": bool(pass_reported_area),
            "benchmark_bbox_frontal_area_pass": bool(pass_bbox_area),
            "benchmark_slant_angle_pass": bool(pass_slant),
            "benchmark_clearance_pass": bool(pass_clearance),
            "benchmark_frontal_overall_pass": bool(overall_pass),
            **checks,
        }
        self.scalar_results.update(results)
        return results

