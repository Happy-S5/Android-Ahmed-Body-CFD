def prepare_export_dir(path: str) -> str:
    try:
        os.makedirs(path, exist_ok=True)
        test_path = os.path.join(path, "_write_test.tmp")
        with open(test_path, "w", encoding="utf-8") as f:
            f.write("ok")
        os.remove(test_path)
        return path
    except OSError:
        fallback = os.getcwd()
        cprint(f"[WARNING] Could not write to {path}; using {fallback}")
        return fallback


