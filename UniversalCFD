    def plot_xz_slices(self, path: str) -> None:
        v = self.voxel
        cy = v["y"].shape[1] // 2
        X = v["x"][:, cy, :]
        Z = v["z"][:, cy, :]
        solid = v["solid_mask"][:, cy, :]
        fields = [
            (np.ma.array(v["speed"][:, cy, :], mask=solid), "Velocity magnitude (m/s)", "Velocity X-Z Centerline"),
            (np.ma.array(v["cp"][:, cy, :], mask=solid), "Pressure coefficient C_p", "Pressure Coefficient X-Z Centerline"),
            (np.ma.array(v["wake_likelihood"][:, cy, :], mask=solid), "Wake likelihood", "Wake Likelihood X-Z Centerline"),
            (np.ma.array(np.minimum(v["yplus"][:, cy, :], 300.0), mask=solid), "y+ clipped at 300", "Commercial-Style y+ X-Z Centerline"),
        ]
        p = self.params
        fig, axes = plt.subplots(4, 1, figsize=(12, 13), sharex=True)
        for ax, (field, label, title) in zip(axes, fields):
            cf = ax.contourf(X, Z, field, levels=80)
            fig.colorbar(cf, ax=ax, label=label)
            # Draw exact side profile outline.
            xs = np.linspace(0, p.length, 120)
            top = p.top_z(xs)
            ax.plot(xs, top, linewidth=2)
            ax.plot([0, p.length], [p.z_bottom, p.z_bottom], linewidth=2)
            ax.plot([0, 0], [p.z_bottom, p.z_top], linewidth=2)
            ax.plot([p.length, p.length], [p.z_bottom, p.z_rear_top], linewidth=2)
            ax.axhline(0.0, linewidth=2)
            ax.set_ylabel("z (m)")
            ax.set_title(title)
            ax.grid(True, linestyle="--", alpha=0.2)
        axes[-1].set_xlabel("x (m)")
        axes[-1].set_xlim(-0.25*p.length, 1.85*p.length)
        axes[-1].set_ylim(0, p.z_top*1.8)
        plt.tight_layout()
        plt.savefig(path, dpi=260)
        plt.close()
        cprint(f"[EXPORT] X-Z slices plot saved: {path}")

    def plot_xy_top(self, path: str) -> None:
        v = self.voxel
        p = self.params
        target_z = p.ground_clearance + 0.48 * p.height
        z_vals = v["z"][0, 0, :]
        iz = int(np.argmin(np.abs(z_vals - target_z)))
        X = v["x"][:, :, iz]
        Y = v["y"][:, :, iz]
        solid = v["solid_mask"][:, :, iz]
        fields = [
            (np.ma.array(v["speed"][:, :, iz], mask=solid), "Velocity magnitude (m/s)", "Top View Velocity"),
            (np.ma.array(v["wake_likelihood"][:, :, iz], mask=solid), "Wake likelihood", "Top View Wake Footprint"),
            (np.ma.array(v["cp"][:, :, iz], mask=solid), "Pressure coefficient C_p", "Top View Pressure Coefficient"),
        ]
        fig, axes = plt.subplots(3, 1, figsize=(12, 11), sharex=True)
        for ax, (field, label, title) in zip(axes, fields):
            cf = ax.contourf(X, Y, field, levels=80)
            fig.colorbar(cf, ax=ax, label=label)
            rect = patches.Rectangle((0, -p.width/2), p.length, p.width, fill=False, linewidth=2)
            ax.add_patch(rect)
            ax.set_ylabel("y (m)")
            ax.set_title(title)
            ax.grid(True, linestyle="--", alpha=0.2)
        axes[-1].set_xlabel("x (m)")
        axes[-1].set_xlim(-0.25*p.length, 1.85*p.length)
        axes[-1].set_ylim(-1.1*p.width, 1.1*p.width)
        plt.tight_layout()
        plt.savefig(path, dpi=260)
        plt.close()
        cprint(f"[EXPORT] X-Y top plot saved: {path}")


def build_arg_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Create an actual Ahmed-body geometry and run reduced-order voxel CFD diagnostics.")
    parser.add_argument("--export-dir", default=INTERNAL_AHMED_DIR, help="Directory for OBJ, Python script, plots, summaries, and NPZ fields.")
    parser.add_argument("--obj-file", default="AhmedGeometry.obj", help="OBJ filename/path. Default expects AhmedGeometry.obj in Download/AhmedGeometry.")
    parser.add_argument("--generate-analytic", action="store_true", help="Ignore any OBJ file and generate an analytic 25-degree Ahmed body mesh.")
    parser.add_argument("--u-inf", type=float, default=40.0, help="Freestream velocity in m/s.")
    parser.add_argument("--iterations", type=int, default=80, help="Coefficient-history iterations.")
    parser.add_argument("--grid", nargs=3, type=int, default=[112, 56, 56], metavar=("NX", "NY", "NZ"), help="Voxel grid shape.")
    parser.add_argument("--mesh", nargs=3, type=int, default=[56, 22, 22], metavar=("NX", "NY", "NZ"), help="Surface mesh divisions.")
    parser.add_argument("--clearance", type=float, default=0.050, help="Ground clearance in meters.")
    parser.add_argument("--slant-angle", type=float, default=25.0, help="Rear upper slant angle in degrees.")
    parser.add_argument("--morph-alpha", type=float, default=0.0, help="Optional Harding normal morphing displacement in meters. Use 0 for exact Ahmed body.")
    return parser


def main(argv: Iterable[str] | None = None) -> int:
    args = build_arg_parser().parse_args(argv)
    export_dir = prepare_export_dir(args.export_dir)
    cprint("=" * 70)
    cprint("ACTUAL AHMED BODY CFD DIAGNOSTIC -- FRONTAL BENCHMARK COMBINED")
    cprint("=" * 70)
    cprint(f"[I/O] Requested Android/internal output folder: {INTERNAL_AHMED_DIR}")
    cprint(f"[I/O] Active output folder: {export_dir}")
    mirrored_script = mirror_current_script_to_export_dir(export_dir)
    params = AhmedBodyParameters(ground_clearance=args.clearance, slant_angle_deg=args.slant_angle)
    cprint(f"[GEOMETRY] L={params.length} m, W={params.width} m, H={params.height} m, clearance={params.ground_clearance} m")
    cprint(f"[GEOMETRY] slant={params.slant_angle_deg} deg, slant start x={params.x_slant_start:.6f} m, rear top z={params.z_rear_top:.6f} m")

    geom = ActualAhmedGeometry(params, nx=args.mesh[0], ny=args.mesh[1], nz=args.mesh[2])
    obj_path = None if args.generate_analytic else resolve_obj_path(args.obj_file, export_dir)
    if obj_path is not None:
        geom.load_obj(obj_path, normalize_to_standard=True)
    else:
        geom.build_mesh()
    expansion = geom.morph_geometry(args.morph_alpha)
    if args.morph_alpha != 0.0:
        cprint(f"[HARDING] Normal morph alpha={args.morph_alpha:.6e} m; bounding expansion={expansion:+.3f}%")
    else:
        cprint("[HARDING] Normal morph alpha=0; geometry remains exact Ahmed body")

    solver = AhmedVoxelCFDDiagnostic(geom, u_inf=args.u_inf, grid_shape=tuple(args.grid))
    solver.compute_frontal_benchmark_criteria()
    solver.print_frontal_benchmark_report()
    solver.run_coefficient_history(iterations=args.iterations)
    solver.build_voxel_field()
    solver.print_descriptive_report()

    geom.export_obj(os.path.join(export_dir, "AhmedBody_25deg_actual.obj"))
    solver.export_csv_history(os.path.join(export_dir, "AhmedBody_CFD_Coefficient_History.csv"))
    solver.export_npz(os.path.join(export_dir, "AhmedBody_CFD_Voxel_Field.npz"))
    solver.export_summary(os.path.join(export_dir, "AhmedBody_CFD_Summary.txt"))
    solver.export_interpretation(os.path.join(export_dir, "AhmedBody_CFD_Interpretation.txt"))
    solver.plot_geometry(os.path.join(export_dir, "AhmedBody_Geometry_3D.png"))
    solver.plot_history(os.path.join(export_dir, "AhmedBody_Coefficients_Residuals.png"))
    solver.plot_xz_slices(os.path.join(export_dir, "AhmedBody_XZ_Velocity_CP_Wake_YPlus.png"))
    solver.plot_xy_top(os.path.join(export_dir, "AhmedBody_XY_Top_View.png"))

    with open(os.path.join(export_dir, "AhmedBody_CFD_Console_Log.txt"), "w", encoding="utf-8") as f:
        f.write("\n".join(CONSOLE) + "\n")
    cprint("[RUN] COMPLETE")
    cprint(f"[RUN] Output directory: {export_dir}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
