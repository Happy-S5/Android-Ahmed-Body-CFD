    def plot_geometry(self, path: str) -> None:
        geom = self.geometry
        assert geom.vertices is not None and geom.faces is not None
        fig = plt.figure(figsize=(10, 7))
        ax = fig.add_subplot(111, projection="3d")
        # Sample faces for render speed.
        faces = geom.faces
        step = max(1, len(faces)//2500)
        polys = [geom.vertices[tri] for tri in faces[::step]]
        pc = Poly3DCollection(polys, alpha=0.85, edgecolor="k", linewidths=0.15)
        ax.add_collection3d(pc)
        p = self.params
        ax.set_xlim(-0.1, p.length*1.1)
        ax.set_ylim(-p.width*0.75, p.width*0.75)
        ax.set_zlim(0.0, p.z_top*1.15)
        ax.set_xlabel("x length (m)")
        ax.set_ylabel("y width (m)")
        ax.set_zlabel("z height (m)")
        ax.set_title("Actual 25-degree Ahmed Body Geometry")
        ax.view_init(elev=22, azim=-58)
        plt.tight_layout()
        plt.savefig(path, dpi=260)
        plt.close()
        cprint(f"[EXPORT] Geometry plot saved: {path}")

