        z_strengths = [6.0, 1.0, 3.0]
        z_widths = [0.045, 0.12, 0.08]

        xg = clustered_axis_sech2(0.0, DOMAIN_X, nx, x_centers, x_strengths, x_widths)
        yg = clustered_axis_sech2(-0.5 * DOMAIN_Y, 0.5 * DOMAIN_Y, ny, y_centers, y_strengths, y_widths)
        zg = clustered_axis_sech2(0.0, DOMAIN_Z, nz, z_centers, z_strengths, z_widths)
