def sample_scalar_nearest_grid(phi, xg, yg, zg, pts):
    vals = np.zeros(len(pts), dtype=float)

    for i, (x, y, z) in enumerate(pts):
        ix = int(np.argmin(np.abs(xg - x)))
        iy = int(np.argmin(np.abs(yg - y)))
        iz = int(np.argmin(np.abs(zg - z)))
        vals[i] = float(phi[ix, iy, iz])

    return vals


def geodesic_pressure_force_coefficients(p_gauge, geo, xg, yg, zg,
                                          rho, U_inf, A_ref):
    q_inf = 0.5 * rho * U_inf * U_inf

    pts = geo["centroid"]
    normals = geo["normal"]
    areas = geo["area"]

    ptri = sample_scalar_nearest_grid(p_gauge, xg, yg, zg, pts)
    force = -np.sum((ptri * areas)[:, None] * normals, axis=0)

    CD_geo = force[0] / max(q_inf * A_ref, 1.0e-30)
    CS_geo = force[1] / max(q_inf * A_ref, 1.0e-30)
    CL_geo = force[2] / max(q_inf * A_ref, 1.0e-30)

    return float(CD_geo), float(CS_geo), float(CL_geo), force


