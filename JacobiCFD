def _safe_norm(v, eps=1.0e-15):
    return float(np.sqrt(np.dot(v, v)) + eps)


def smoothstep(edge0, edge1, x):
    if edge1 == edge0:
        return np.zeros_like(x, dtype=float)
    t = np.clip((x - edge0) / (edge1 - edge0), 0.0, 1.0)
    return t * t * (3.0 - 2.0 * t)


def polygon_signed_area_yz(poly):
    p = np.asarray(poly, dtype=float)
    y = p[:, 0]
    z = p[:, 1]
    return 0.5 * np.sum(y * np.roll(z, -1) - np.roll(y, -1) * z)


def polygon_area_centroid_yz(poly):
    p = np.asarray(poly, dtype=float)
    if len(p) < 3:
        return 0.0, 0.0, 0.0

    y = p[:, 0]
    z = p[:, 1]
    y2 = np.roll(y, -1)
    z2 = np.roll(z, -1)
    cross = y * z2 - y2 * z
    A_signed = 0.5 * np.sum(cross)
    A = abs(A_signed)

    if A < 1.0e-15:
        return 0.0, float(np.mean(y)), float(np.mean(z))

    cy = np.sum((y + y2) * cross) / (6.0 * A_signed)
    cz = np.sum((z + z2) * cross) / (6.0 * A_signed)
    return A, float(cy), float(cz)


def convex_hull_2d(points):
    pts = np.asarray(points, dtype=float)
    if len(pts) < 3:
        return pts

    pts = np.unique(np.round(pts, 12), axis=0)
    pts = pts[np.lexsort((pts[:, 1], pts[:, 0]))]

    def cross(o, a, b):
        return (a[0] - o[0]) * (b[1] - o[1]) - (a[1] - o[1]) * (b[0] - o[0])

    lower = []
    for p in pts:
        while len(lower) >= 2 and cross(lower[-2], lower[-1], p) <= 0:
            lower.pop()
        lower.append(p)

    upper = []
    for p in pts[::-1]:
        while len(upper) >= 2 and cross(upper[-2], upper[-1], p) <= 0:
            upper.pop()
        upper.append(p)

    hull = np.asarray(lower[:-1] + upper[:-1], dtype=float)
    return hull


def points_in_polygon_yz(Y, Z, poly):
    poly = np.asarray(poly, dtype=float)
    yv = poly[:, 0]
    zv = poly[:, 1]

    inside = np.zeros_like(Y, dtype=bool)
    j = len(poly) - 1

    for i in range(len(poly)):
        yi, zi = yv[i], zv[i]
        yj, zj = yv[j], zv[j]

        intersects = ((zi > Z) != (zj > Z)) & (
            Y < (yj - yi) * (Z - zi) / ((zj - zi) + 1.0e-30) + yi
        )
        inside ^= intersects
        j = i

    return inside


# ============================================================
# 6. HYPERBOLIC-TANGENT / SECH^2 GRID UTILITIES
# ============================================================

def sech2(x):
    x = np.clip(x, -40.0, 40.0)
    c = np.cosh(x)
    return 1.0 / (c * c)


def clustered_axis_sech2(xmin, xmax, n, centers, strengths, widths, samples=12000):
    """
    Create a monotone nonuniform axis by sampling a density field.
    Higher density means smaller local spacing. The density bumps are sech^2,
    the derivative of tanh, so this implements hyperbolic-tangent-style clustering.
    """
    if n < 3:
        return np.linspace(xmin, xmax, n)

    s = np.linspace(xmin, xmax, samples)
    density = np.ones_like(s)

    for c, a, w in zip(centers, strengths, widths):
        w = max(float(w), 1.0e-9)
        density += float(a) * sech2((s - float(c)) / w)

    density = np.maximum(density, 1.0e-6)
    cumulative = np.zeros_like(s)
    cumulative[1:] = np.cumsum(0.5 * (density[1:] + density[:-1]) * np.diff(s))
    cumulative /= max(cumulative[-1], 1.0e-30)

    target = np.linspace(0.0, 1.0, n)
    axis = np.interp(target, cumulative, s)
    axis[0] = xmin
    axis[-1] = xmax
    return axis


def cell_widths(coords):
    c = np.asarray(coords, dtype=float)
    w = np.empty_like(c)
    w[0] = c[1] - c[0]
    w[-1] = c[-1] - c[-2]
    w[1:-1] = 0.5 * (c[2:] - c[:-2])
    return np.maximum(w, 1.0e-30)


def min_grid_spacing(xg, yg, zg):
    return float(min(np.min(np.diff(xg)), np.min(np.diff(yg)), np.min(np.diff(zg))))


