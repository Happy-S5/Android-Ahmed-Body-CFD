def find_obj_file():
    """Find a real Ahmed OBJ. This 3D version has no procedural fallback."""
    names = [
        "Ahmed_Body.obj",
        "Ahmed Body.obj",
        "ahmed_body.obj",
        "ahmed body.obj",
        "AhmedGeometry.obj",
        "AhmedGeomtry.obj",
    ]
    folders = [
        OUTPUT_DIR,
        Path("/storage/emulated/0/Download/AhmedGeometry"),
        Path("/sdcard/Download/AhmedGeometry"),
        Path.home() / "Downloads" / "AhmedGeometry",
        Path.cwd(),
        Path("/mnt/data"),
    ]
    for folder in folders:
        for name in names:
            p = folder / name
            if p.exists():
                return p
    for folder in folders:
        try:
            objs = sorted(folder.glob("*.obj"))
        except Exception:
            objs = []
        if objs:
            return objs[0]
    return None


def load_obj_triangles(path):
    vertices = []
    faces = []

    with open(path, "r", encoding="utf-8", errors="ignore") as f:
        for line in f:
            if line.startswith("v "):
                parts = line.strip().split()
                if len(parts) >= 4:
                    vertices.append([float(parts[1]), float(parts[2]), float(parts[3])])
            elif line.startswith("f "):
                parts = line.strip().split()[1:]
                idxs = []
                for part in parts:
                    raw = part.split("/")[0]
                    if not raw:
                        continue
                    idx = int(raw)
                    if idx < 0:
                        idx = len(vertices) + idx
                    else:
                        idx = idx - 1
                    idxs.append(idx)

                if len(idxs) >= 3:
                    for k in range(1, len(idxs) - 1):
                        faces.append([idxs[0], idxs[k], idxs[k + 1]])

    v = np.asarray(vertices, dtype=float)
    f = np.asarray(faces, dtype=int)
    return v, f


def auto_orient_scale_obj_vertices(vertices):
    """
    Auto-orient by extents:
      longest axis -> x
      second       -> y
      third        -> z
    Then scale to Ahmed dimensions and place in CFD domain.
    """
    v = np.asarray(vertices, dtype=float)
    mins = np.min(v, axis=0)
    maxs = np.max(v, axis=0)
    ext = maxs - mins

    order = np.argsort(ext)[::-1]
    w = v[:, order].copy()

    mins = np.min(w, axis=0)
    maxs = np.max(w, axis=0)
    ext = np.maximum(maxs - mins, 1.0e-12)

    out = np.zeros_like(w)
    out[:, 0] = BODY_X0 + (w[:, 0] - mins[0]) / ext[0] * BODY_L
    out[:, 1] = ((w[:, 1] - mins[1]) / ext[1] - 0.5) * BODY_W
    out[:, 2] = (w[:, 2] - mins[2]) / ext[2] * BODY_H

    return out


def triangle_xplane_intersection_yz(tri, xp):
    pts = []
    for a, b in [(tri[0], tri[1]), (tri[1], tri[2]), (tri[2], tri[0])]:
        x1 = a[0]
        x2 = b[0]

        if abs(x1 - xp) < 1.0e-12 and abs(x2 - xp) < 1.0e-12:
            continue

        if (x1 - xp) * (x2 - xp) <= 0.0 and abs(x2 - x1) > 1.0e-15:
            t = (xp - x1) / (x2 - x1)
            if -1.0e-12 <= t <= 1.0 + 1.0e-12:
                p = a + t * (b - a)
                pts.append([p[1], p[2]])

    if len(pts) < 2:
        return []

    pts = np.asarray(pts, dtype=float)
    pts = np.unique(np.round(pts, 12), axis=0)

    if len(pts) < 2:
        return []

    return pts.tolist()


def make_sections_from_obj(vertices, faces, n_sections):
    verts = auto_orient_scale_obj_vertices(vertices)
    xs = np.linspace(BODY_X0, BODY_X1, n_sections)

    triangles = verts[faces]
    section_x = []
    section_polys = []

    for xp in xs:
        pts = []
        for tri in triangles:
            seg = triangle_xplane_intersection_yz(tri, xp)
            pts.extend(seg)

        if len(pts) >= 3:
            hull = convex_hull_2d(pts)
            A, cy, cz = polygon_area_centroid_yz(hull)
            if A > 1.0e-8:
                section_x.append(xp)
                section_polys.append(hull)

    if len(section_x) < 8:
        raise RuntimeError("OBJ slicing produced too few valid sections.")

    return np.asarray(section_x), section_polys


def procedural_ahmed_polygon_at_x(x):
    """Simple Ahmed-like swept cross-section."""
    slant_dx = SLANT_LEN * math.cos(SLANT_ANGLE)
    slant_start = BODY_X1 - slant_dx

    if x <= slant_start:
        h = BODY_H
    else:
        drop = math.tan(SLANT_ANGLE) * (x - slant_start)
        h = max(BODY_H - drop, 0.52 * BODY_H)

    y0 = -0.5 * BODY_W
    y1 = 0.5 * BODY_W
    z0 = 0.0
    z1 = h

    return np.asarray([
        [y0, z0],
        [y1, z0],
        [y1, z1],
        [y0, z1],
    ], dtype=float)


def make_procedural_sections(n_sections):
    xs = np.linspace(BODY_X0, BODY_X1, n_sections)
    polys = [procedural_ahmed_polygon_at_x(x) for x in xs]
    return xs, polys


def load_or_make_sections():
    """Load only the OBJ mesh and slice it into 3D body sections.

    There is intentionally no created/procedural Ahmed fallback here. If the OBJ
    is missing or cannot be sliced, the solver stops so results cannot be
    confused with generated geometry.
    """
    obj = find_obj_file()
    if obj is None:
        raise FileNotFoundError(
            "No OBJ file found. Put Ahmed_Body.obj or AhmedGeometry.obj in "
            "/storage/emulated/0/Download/AhmedGeometry or pass/run from a folder containing an .obj."
        )
    log(f"OBJ LOAD CONFIRMED: {obj}")
    v, f = load_obj_triangles(obj)
    if len(v) == 0 or len(f) == 0:
        raise ValueError(f"OBJ file has no usable vertices/faces: {obj}")
    log(f"OBJ vertices={len(v)}, triangles={len(f)}")
    sx, sp = make_sections_from_obj(v, f, CFG["n_sections"])
    log(f"OBJ sectional polygons created: {len(sx)}")
    return sx, sp, f"OBJ imported and convex-sliced: {obj}"


