class TeeWriter:
    """Mirror stdout/stderr to a live-updating text file."""
    def __init__(self, terminal, file_path):
        self.terminal = terminal
        self.file = open(file_path, "a", encoding="utf-8", buffering=1)

    def write(self, message):
        self.terminal.write(message)
        self.file.write(message)
        self.flush()

    def flush(self):
        try:
            self.terminal.flush()
        except Exception:
            pass
        try:
            self.file.flush()
            os.fsync(self.file.fileno())
        except Exception:
            pass

    def close(self):
        try:
            self.file.close()
        except Exception:
            pass

