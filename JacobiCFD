def apply_boundary_conditions(u, v, w, p, body):
    u[0, :, :] = U_INF
    v[0, :, :] = 0.0
    w[0, :, :] = 0.0

    u[-1, :, :] = u[-2, :, :]
    v[-1, :, :] = v[-2, :, :]
    w[-1, :, :] = w[-2, :, :]
    p[-1, :, :] = 0.0

    u[:, 0, :] = u[:, 1, :]
    v[:, 0, :] = 0.0
    w[:, 0, :] = w[:, 1, :]
    p[:, 0, :] = p[:, 1, :]

    u[:, -1, :] = u[:, -2, :]
    v[:, -1, :] = 0.0
    w[:, -1, :] = w[:, -2, :]
    p[:, -1, :] = p[:, -2, :]

    # Ground no-slip
    u[:, :, 0] = 0.0
    v[:, :, 0] = 0.0
    w[:, :, 0] = 0.0
    p[:, :, 0] = p[:, :, 1]

    # Top slip/freestream
    u[:, :, -1] = u[:, :, -2]
    v[:, :, -1] = v[:, :, -2]
    w[:, :, -1] = 0.0
    p[:, :, -1] = p[:, :, -2]

    u[body] = 0.0
    v[body] = 0.0
    w[body] = 0.0

    return u, v, w, p


def dd_axis(phi, coords, axis):
    """First derivative on nonuniform cell-centered coordinates."""
    f = np.moveaxis(phi, axis, 0)
    x = np.asarray(coords, dtype=float)
    out = np.zeros_like(f)

    hm = x[1:-1] - x[:-2]
    hp = x[2:] - x[1:-1]
    shape = (len(hm),) + (1,) * (f.ndim - 1)
    hm_b = hm.reshape(shape)
    hp_b = hp.reshape(shape)

    out[1:-1] = (
        hm_b * hm_b * (f[2:] - f[1:-1])
        + hp_b * hp_b * (f[1:-1] - f[:-2])
    ) / np.maximum(hm_b * hp_b * (hm_b + hp_b), 1.0e-30)

    out[0] = (f[1] - f[0]) / max(x[1] - x[0], 1.0e-30)
    out[-1] = (f[-1] - f[-2]) / max(x[-1] - x[-2], 1.0e-30)

    return np.moveaxis(out, 0, axis)


def second_axis(phi, coords, axis):
    """Second derivative on nonuniform cell-centered coordinates."""
    f = np.moveaxis(phi, axis, 0)
    x = np.asarray(coords, dtype=float)
    out = np.zeros_like(f)

    hm = x[1:-1] - x[:-2]
    hp = x[2:] - x[1:-1]
    shape = (len(hm),) + (1,) * (f.ndim - 1)
    hm_b = hm.reshape(shape)
    hp_b = hp.reshape(shape)

    out[1:-1] = 2.0 * (
        (f[2:] - f[1:-1]) / np.maximum(hp_b, 1.0e-30)
        - (f[1:-1] - f[:-2]) / np.maximum(hm_b, 1.0e-30)
    ) / np.maximum(hm_b + hp_b, 1.0e-30)

    out[0] = out[1]
    out[-1] = out[-2]

    return np.moveaxis(out, 0, axis)


def laplacian(phi, xg, yg, zg):
    return second_axis(phi, xg, 0) + second_axis(phi, yg, 1) + second_axis(phi, zg, 2)


def divergence(u, v, w, xg, yg, zg):
    return dd_axis(u, xg, 0) + dd_axis(v, yg, 1) + dd_axis(w, zg, 2)


def limiter_slope(backward, forward, kind="vanleer"):
    same = backward * forward > 0.0
    if kind.lower() == "minmod":
        return np.where(same, np.sign(backward) * np.minimum(np.abs(backward), np.abs(forward)), 0.0)
    # Van Leer harmonic limiter
    denom = backward + forward
    val = np.where(np.abs(denom) > 1.0e-30, 2.0 * backward * forward / denom, 0.0)
    return np.where(same, val, 0.0)


def tvd_flux_derivative(phi, adv_vel, coords, axis, limiter=TVD_LIMITER):
    """
    Conservative MUSCL/TVD derivative d(adv_vel*phi)/dx on nonuniform grids.
    This is the hyperbolic transport upgrade. For incompressible flow,
    conservative and advective forms approach equivalence as divergence decreases.
    """
    f = np.moveaxis(phi, axis, 0)
    a = np.moveaxis(adv_vel, axis, 0)
    x = np.asarray(coords, dtype=float)
    n = f.shape[0]

    slopes = np.zeros_like(f)
    dx_b = (x[1:-1] - x[:-2]).reshape((n - 2,) + (1,) * (f.ndim - 1))
    dx_f = (x[2:] - x[1:-1]).reshape((n - 2,) + (1,) * (f.ndim - 1))
    sb = (f[1:-1] - f[:-2]) / np.maximum(dx_b, 1.0e-30)
    sf = (f[2:] - f[1:-1]) / np.maximum(dx_f, 1.0e-30)
    slopes[1:-1] = limiter_slope(sb, sf, limiter)

    flux = np.zeros((n + 1,) + f.shape[1:], dtype=f.dtype)

    # Boundary face fluxes are first-order guarded.
    flux[0] = a[0] * f[0]
    flux[-1] = a[-1] * f[-1]

    for k in range(1, n):
        x_face = 0.5 * (x[k - 1] + x[k])
        vel_face = 0.5 * (a[k - 1] + a[k])
        left = f[k - 1] + slopes[k - 1] * (x_face - x[k - 1])
        right = f[k] - slopes[k] * (x[k] - x_face)
        flux[k] = np.where(vel_face >= 0.0, vel_face * left, vel_face * right)

    widths = cell_widths(x).reshape((n,) + (1,) * (f.ndim - 1))
    deriv = (flux[1:] - flux[:-1]) / np.maximum(widths, 1.0e-30)
    return np.moveaxis(deriv, 0, axis)


def upwind_deriv(phi, vel, coords, axis):
    """Fallback first-order advective derivative on nonuniform grids."""
    f = np.moveaxis(phi, axis, 0)
    a = np.moveaxis(vel, axis, 0)
    x = np.asarray(coords, dtype=float)
    out = np.zeros_like(f)

    dx_b = (x[1:] - x[:-1]).reshape((len(x) - 1,) + (1,) * (f.ndim - 1))
    backward = np.zeros_like(f)
    forward = np.zeros_like(f)

    backward[1:] = (f[1:] - f[:-1]) / np.maximum(dx_b, 1.0e-30)
    backward[0] = backward[1]

    forward[:-1] = (f[1:] - f[:-1]) / np.maximum(dx_b, 1.0e-30)
    forward[-1] = forward[-2]

    out = np.where(a >= 0.0, backward, forward)
    return np.moveaxis(out, 0, axis)


def strain_magnitude(u, v, w, xg, yg, zg):
    ux = dd_axis(u, xg, 0)
    uy = dd_axis(u, yg, 1)
    uz = dd_axis(u, zg, 2)

    vx = dd_axis(v, xg, 0)
    vy = dd_axis(v, yg, 1)
    vz = dd_axis(v, zg, 2)

    wx = dd_axis(w, xg, 0)
    wy = dd_axis(w, yg, 1)
    wz = dd_axis(w, zg, 2)

    sxx = ux
    syy = vy
    szz = wz
    sxy = 0.5 * (uy + vx)
    sxz = 0.5 * (uz + wx)
    syz = 0.5 * (vz + wy)

    S2 = 2.0 * (sxx*sxx + syy*syy + szz*szz + 2.0*(sxy*sxy + sxz*sxz + syz*syz))
    return np.sqrt(np.maximum(S2, 0.0))


def pressure_poisson_nonuniform(p, rhs, xg, yg, zg, iters):
    """Jacobi pressure Poisson update for a nonuniform Cartesian grid."""
    x = np.asarray(xg)
    y = np.asarray(yg)
    z = np.asarray(zg)

    hxm = x[1:-1] - x[:-2]
    hxp = x[2:] - x[1:-1]
    hym = y[1:-1] - y[:-2]
    hyp = y[2:] - y[1:-1]
    hzm = z[1:-1] - z[:-2]
    hzp = z[2:] - z[1:-1]

    cxm = (2.0 / np.maximum(hxm * (hxm + hxp), 1.0e-30))[:, None, None]
    cxp = (2.0 / np.maximum(hxp * (hxm + hxp), 1.0e-30))[:, None, None]
    cym = (2.0 / np.maximum(hym * (hym + hyp), 1.0e-30))[None, :, None]
    cyp = (2.0 / np.maximum(hyp * (hym + hyp), 1.0e-30))[None, :, None]
    czm = (2.0 / np.maximum(hzm * (hzm + hzp), 1.0e-30))[None, None, :]
    czp = (2.0 / np.maximum(hzp * (hzm + hzp), 1.0e-30))[None, None, :]

    denom = cxm + cxp + cym + cyp + czm + czp

    for _ in range(iters):
        pn = p.copy()
        p[1:-1, 1:-1, 1:-1] = (
            cxm * pn[:-2, 1:-1, 1:-1]
            + cxp * pn[2:, 1:-1, 1:-1]
            + cym * pn[1:-1, :-2, 1:-1]
            + cyp * pn[1:-1, 2:, 1:-1]
            + czm * pn[1:-1, 1:-1, :-2]
            + czp * pn[1:-1, 1:-1, 2:]
            - rhs[1:-1, 1:-1, 1:-1]
        ) / np.maximum(denom, 1.0e-30)

        p[0, :, :] = p[1, :, :]
        p[-1, :, :] = 0.0
        p[:, 0, :] = p[:, 1, :]
        p[:, -1, :] = p[:, -2, :]
        p[:, :, 0] = p[:, :, 1]
        p[:, :, -1] = p[:, :, -2]

    return p


def pseudo_compressibility_preconditioner(p, div_star, dt, body):
    if not USE_PSEUDO_COMPRESSIBILITY_PRECONDITIONER:
        return p
    p = p - PSEUDO_RELAX * RHO * PSEUDO_BETA * PSEUDO_BETA * dt * div_star
    p[body] = 0.0
    return p


def compute_wall_distance(body_mask, min_spacing):
    if SCIPY_OK:
        fluid = ~body_mask
        dist_cells = distance_transform_cdt(fluid, metric="taxicab").astype(float)
        return dist_cells * min_spacing
    return np.ones_like(body_mask, dtype=float) * min_spacing


def wake_momentum_cd(u, xg, yg, zg, body_x1):
    target_x = body_x1 + 0.75 * BODY_L
    ix = int(np.argmin(np.abs(xg - target_x)))

    U = np.maximum(u[ix, :, :], 0.0)
    deficit = np.maximum(U_INF - U, 0.0)

    wy = cell_widths(yg)
    wz = cell_widths(zg)
    dA = wy[:, None] * wz[None, :]

    drag = np.sum(RHO * U * deficit * dA)
    cd = drag / max(Q_INF * A_REF, 1.0e-30)
    return float(cd)


