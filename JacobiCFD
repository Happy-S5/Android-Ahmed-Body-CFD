def run_solver():
    start_wall = time.time()

    log(f"Run mode: {RUN_MODE}")
    log(f"Output directory: {OUTPUT_DIR}")
    log(f"Grid: {CFG['nx']} x {CFG['ny']} x {CFG['nz']}")
    log(f"Steps: {CFG['num_steps']}")
    log(f"Re_L = {RE_L:.6e}")
    log(f"Real-physics target Re_L   : {TARGET_RE_L:.6e}")
    log(f"Active/Recomputed Re_L     : {RE_L:.6e}")
    log(f"Air viscosity active       : {MU:.6e} Pa s")
    log(f"Kinematic viscosity active : {NU:.6e} m^2/s")
    log(f"DNS-like legacy flag       : {USE_DNS_LIKE_MODE}")
    if USE_DNS_LIKE_MODE:
        log("WARNING: high-Re DNS-like mode is not physically resolved on this grid; RANS/DDES modes are recommended.")
        log("Modeled eddy viscosity     : OFF (legacy experimental setting)")
    else:
        log("Modeled eddy viscosity     : ON (RANS/DDES-style mixing-length model)")
    log(f"Hyperbolic tanh/sech2 grid : {USE_HYPERBOLIC_TANH_GRID}")
    log(f"TVD hyperbolic advection   : {USE_TVD_HYPERBOLIC_ADVECTION} ({TVD_LIMITER})")
    log(f"Live console file          : {LIVE_CONSOLE_PATH}")

    section_x, section_polys, geometry_source = load_or_make_sections()
    sec = compute_sectional_metrics(section_x, section_polys)

    log("")
    log("=== SECTIONAL GEOMETRY ===")
    log(f"Geometry source       : {geometry_source}")
    log(f"Sections              : {len(section_x)}")
    log(f"Sectional volume      : {sec['volume']:.9e} m^3")
    log(f"Sectional xcg         : {sec['xcg']:.9e} m")
    log(f"Sectional ycg         : {sec['ycg']:.9e} m")
    log(f"Sectional zcg         : {sec['zcg']:.9e} m")

    geo_boundary = None

    if USE_GEODESIC_BOUNDARY_TRIANGLES:
        geo_boundary = build_swept_geodesic_boundary_triangles(
            section_x=section_x,
            section_polygons_yz=section_polys,
            n_per_section=GEODESIC_POINTS_PER_SECTION
        )

        log("")
        log(summarize_geodesic_boundary(geo_boundary))
        write_geodesic_boundary_csv(GEODESIC_TRI_CSV, geo_boundary)

    xg, yg, zg, dx_min, dy_min, dz_min = make_grid()
    hmin = min_grid_spacing(xg, yg, zg)

    log("")
    log("=== GRID METRICS ===")
    log(f"x spacing min/max     : {np.min(np.diff(xg)):.6e} / {np.max(np.diff(xg)):.6e} m")
    log(f"y spacing min/max     : {np.min(np.diff(yg)):.6e} / {np.max(np.diff(yg)):.6e} m")
    log(f"z spacing min/max     : {np.min(np.diff(zg)):.6e} / {np.max(np.diff(zg)):.6e} m")
    log(f"minimum spacing       : {hmin:.6e} m")

    body = make_body_mask_from_sections(xg, yg, zg, section_x, section_polys)
    vox = compute_voxel_metrics(body, xg, yg, zg)

    vol_error = 100.0 * (vox["volume"] - sec["volume"]) / max(sec["volume"], 1.0e-30)

    log("")
    log("=== VOXEL GEOMETRY ===")
    log(f"Voxel cells           : {vox['cells']}")
    log(f"Voxel volume          : {vox['volume']:.9e} m^3")
    log(f"Voxel volume error    : {vol_error:+.6f} %")
    log(f"Voxel xcg             : {vox['xcg']:.9e} m")
    log(f"Voxel ycg             : {vox['ycg']:.9e} m")
    log(f"Voxel zcg             : {vox['zcg']:.9e} m")

    if USE_GEODESIC_WAKE_LIKELIHOOD and geo_boundary is not None:
        boundary_likelihood, corner_likelihood, wake_likelihood_base = map_geodesic_boundary_to_grid(
            geo_boundary, xg, yg, zg, body_mask=body
        )
    else:
        boundary_likelihood = np.zeros_like(body, dtype=np.float32)
        corner_likelihood = np.zeros_like(body, dtype=np.float32)
        wake_likelihood_base = np.zeros_like(body, dtype=np.float32)

    wake_likelihood, recursive_wake_eddies, wake_analysis = recursive_euler_wake_eddy_refinement(
        wake_likelihood_base,
        geo_boundary,
        xg, yg, zg,
        body_mask=body,
    )
    write_recursive_euler_wake_csv(EULER_WAKE_EDDY_CSV, recursive_wake_eddies)
    write_wake_analysis_txt(EULER_WAKE_ANALYSIS_TXT, wake_analysis)

    log("")
    log("=== GEODESIC + RECURSIVE EULER WAKE FIELDS ===")
    log(f"Boundary likelihood max : {float(np.max(boundary_likelihood)):.6f}")
    log(f"Corner likelihood max   : {float(np.max(corner_likelihood)):.6f}")
    log(f"Base wake max           : {wake_analysis['base_max']:.6f}")
    log(f"Base wake mean          : {wake_analysis['base_mean']:.6e}")
    log(f"Refined wake max        : {wake_analysis['refined_max']:.6f}")
    log(f"Refined wake mean       : {wake_analysis['refined_mean']:.6e}")
    log(f"Recursive Euler eddies  : {wake_analysis['eddy_count']}")
    log(f"Wake importance score   : {wake_analysis['importance_score']:.3f} ({wake_analysis['decision']})")
    if USE_DNS_LIKE_MODE:
        log("Wake likelihood use      : diagnostic/refinement map only; does not modify nu_t")

    nx, ny, nz = len(xg), len(yg), len(zg)

    u = np.ones((nx, ny, nz), dtype=np.float64) * U_INF
    v = np.zeros_like(u)
    w = np.zeros_like(u)
    p = np.zeros_like(u)

    nu_t = np.zeros_like(u)
    wall_dist = compute_wall_distance(body, hmin)

    u, v, w, p = apply_boundary_conditions(u, v, w, p, body)

    dns_init_metrics = {
        "enabled": False, "eddy_count_used": 0, "epsilon_fraction": 0.0,
        "max_du": 0.0, "max_dv": 0.0, "max_dw": 0.0,
        "l2_before_projection": 0.0, "div_before_projection": 0.0, "div_after_projection": 0.0, "note": "not DNS-like mode"
    }

    if USE_DNS_LIKE_MODE:
        u, v, w, dns_init_metrics = apply_recursive_euler_dns_initial_perturbation(
            u, v, w, recursive_wake_eddies, xg, yg, zg, body
        )
        u, v, w, p = apply_boundary_conditions(u, v, w, p, body)

        if DNS_PROJECT_INITIAL_PERTURBATION and dns_init_metrics.get("enabled", False):
            div0 = divergence(u, v, w, xg, yg, zg)
            dns_init_metrics["div_before_projection"] = float(np.sqrt(np.mean(div0[~body] ** 2)))
            speed0 = np.sqrt(u*u + v*v + w*w)
            umax0 = max(float(np.max(speed0)), 1.0e-9)
            dt0 = min(CFG["cfl_target"] * hmin / umax0, 1.0e-4)
            rhs0 = RHO / max(dt0, 1.0e-30) * div0
            rhs0[body] = 0.0
            p = pressure_poisson_nonuniform(p, rhs0, xg, yg, zg, max(20, CFG["poisson_iters"] // 2))
            u = u - dt0 / RHO * dd_axis(p, xg, 0)
            v = v - dt0 / RHO * dd_axis(p, yg, 1)
            w = w - dt0 / RHO * dd_axis(p, zg, 2)
            u, v, w, p = apply_boundary_conditions(u, v, w, p, body)
            div1 = divergence(u, v, w, xg, yg, zg)
            dns_init_metrics["div_after_projection"] = float(np.sqrt(np.mean(div1[~body] ** 2)))

        log("")
        log("=== DNS-LIKE INITIAL PERTURBATION ===")
        log(f"Euler perturbation enabled : {dns_init_metrics['enabled']}")
        log(f"Eddies used               : {dns_init_metrics['eddy_count_used']}")
        log(f"epsilon * U_inf           : {dns_init_metrics['epsilon_fraction']:.6e}")
        log(f"max |du,dv,dw|            : {dns_init_metrics['max_du']:.3e}, {dns_init_metrics['max_dv']:.3e}, {dns_init_metrics['max_dw']:.3e} m/s")
        log(f"div before/after project  : {dns_init_metrics.get('div_before_projection', 0.0):.3e} / {dns_init_metrics.get('div_after_projection', 0.0):.3e}")

    write_dns_like_analysis_txt(DNS_LIKE_ANALYSIS_TXT, dns_init_metrics, wake_analysis)

    history = []

    with open(HISTORY_CSV, "w", newline="", encoding="utf-8") as f:
        writer = csv.writer(f)
        writer.writerow([
            "step", "time", "dt", "cfl",
            "div_l2",
            "CD_wake",
            "CD_geo_p", "CS_geo_p", "CL_geo_p",
            "u_mean", "u_max",
            "nu_t_mean", "nu_t_max",
            "wake_mean", "wake_max",
            "wake_active_fraction",
            "wake_refinement_delta_mean",
            "wake_importance_score"
        ])

    sim_time = 0.0

    for step in range(1, CFG["num_steps"] + 1):
        speed = np.sqrt(u*u + v*v + w*w)
        umax = max(float(np.max(speed)), 1.0e-9)

        dt = CFG["cfl_target"] * hmin / umax
        dt = min(dt, 1.0e-4)
        cfl = umax * dt / hmin

        if USE_DNS_LIKE_MODE:
            # DNS-like mode: no modeled eddy viscosity and no wake-likelihood
            # viscosity correction. Only molecular viscosity is used.
            nu_t.fill(0.0)
            nu_eff = NU
        else:
            S = strain_magnitude(u, v, w, xg, yg, zg)
            lm = np.minimum(KAPPA * wall_dist, MIXING_LIMIT)
            nu_t_new = np.minimum(lm * lm * S, NU_T_MAX)

            if GEODESIC_WAKE_REDUCE_NUT:
                nu_t_new *= (1.0 - GEODESIC_WAKE_NUT_REDUCTION * wake_likelihood)
                nu_t_new = np.maximum(nu_t_new, 0.0)

            nu_t = (1.0 - NU_T_RELAX) * nu_t + NU_T_RELAX * nu_t_new
            nu_eff = NU + nu_t

        if USE_TVD_HYPERBOLIC_ADVECTION:
            conv_u = (
                tvd_flux_derivative(u, u, xg, 0)
                + tvd_flux_derivative(u, v, yg, 1)
                + tvd_flux_derivative(u, w, zg, 2)
            )
            conv_v = (
                tvd_flux_derivative(v, u, xg, 0)
                + tvd_flux_derivative(v, v, yg, 1)
                + tvd_flux_derivative(v, w, zg, 2)
            )
            conv_w = (
                tvd_flux_derivative(w, u, xg, 0)
                + tvd_flux_derivative(w, v, yg, 1)
                + tvd_flux_derivative(w, w, zg, 2)
            )
        else:
            du_dx = upwind_deriv(u, u, xg, 0)
            du_dy = upwind_deriv(u, v, yg, 1)
            du_dz = upwind_deriv(u, w, zg, 2)

            dv_dx = upwind_deriv(v, u, xg, 0)
            dv_dy = upwind_deriv(v, v, yg, 1)
            dv_dz = upwind_deriv(v, w, zg, 2)

            dw_dx = upwind_deriv(w, u, xg, 0)
            dw_dy = upwind_deriv(w, v, yg, 1)
            dw_dz = upwind_deriv(w, w, zg, 2)

            conv_u = u * du_dx + v * du_dy + w * du_dz
            conv_v = u * dv_dx + v * dv_dy + w * dv_dz
            conv_w = u * dw_dx + v * dw_dy + w * dw_dz

        u_star = u + dt * (-conv_u + nu_eff * laplacian(u, xg, yg, zg))
        v_star = v + dt * (-conv_v + nu_eff * laplacian(v, xg, yg, zg))
        w_star = w + dt * (-conv_w + nu_eff * laplacian(w, xg, yg, zg))

        u_star[body] = 0.0
        v_star[body] = 0.0
        w_star[body] = 0.0

        u_star, v_star, w_star, p = apply_boundary_conditions(u_star, v_star, w_star, p, body)

        div_star = divergence(u_star, v_star, w_star, xg, yg, zg)
        rhs = RHO / max(dt, 1.0e-30) * div_star
        rhs[body] = 0.0

        p = pseudo_compressibility_preconditioner(p, div_star, dt, body)
        p = pressure_poisson_nonuniform(p, rhs, xg, yg, zg, CFG["poisson_iters"])

        dpdx = dd_axis(p, xg, 0)
        dpdy = dd_axis(p, yg, 1)
        dpdz = dd_axis(p, zg, 2)

        u = u_star - dt / RHO * dpdx
        v = v_star - dt / RHO * dpdy
        w = w_star - dt / RHO * dpdz

        u, v, w, p = apply_boundary_conditions(u, v, w, p, body)

        sim_time += dt

        div_now = divergence(u, v, w, xg, yg, zg)
        div_l2 = float(np.sqrt(np.mean(div_now[~body] ** 2)))

        CD_wake = wake_momentum_cd(u, xg, yg, zg, BODY_X1)

        if USE_GEODESIC_PRESSURE_FORCE and geo_boundary is not None:
            CD_geo_p, CS_geo_p, CL_geo_p, F_geo_p = geodesic_pressure_force_coefficients(
                p_gauge=p,
                geo=geo_boundary,
                xg=xg,
                yg=yg,
                zg=zg,
                rho=RHO,
                U_inf=U_INF,
                A_ref=A_REF
            )
        else:
            CD_geo_p, CS_geo_p, CL_geo_p = 0.0, 0.0, 0.0

        u_mean = float(np.mean(u[~body]))
        u_max = float(np.max(np.sqrt(u*u + v*v + w*w)))
        nut_mean = float(np.mean(nu_t[~body]))
        nut_max = float(np.max(nu_t))

        row = [
            step, sim_time, dt, cfl,
            div_l2,
            CD_wake,
            CD_geo_p, CS_geo_p, CL_geo_p,
            u_mean, u_max,
            nut_mean, nut_max,
            float(np.mean(wake_likelihood)),
            float(np.max(wake_likelihood)),
            float(wake_analysis["refined_active_fraction"]),
            float(wake_analysis["delta_mean"]),
            float(wake_analysis["importance_score"]),
        ]

        history.append(row)

        with open(HISTORY_CSV, "a", newline="", encoding="utf-8") as f:
            writer = csv.writer(f)
            writer.writerow(row)
            f.flush()
            os.fsync(f.fileno())

        if step == 1 or step % CFG["log_every"] == 0 or step == CFG["num_steps"]:
            log(
                f"step={step:5d} "
                f"t={sim_time:.6e} "
                f"dt={dt:.3e} "
                f"CFL={cfl:.3f} "
                f"divL2={div_l2:.4e} "
                f"CDwake={CD_wake:.5f} "
                f"CDgeoP={CD_geo_p:.5f} "
                f"CLgeoP={CL_geo_p:.5f} "
                f"nutMean={nut_mean:.3e}"
            )

    history = np.asarray(history, dtype=float)

    avg_start = int(0.65 * len(history))
    tail = history[avg_start:]

    CD_wake_avg = float(np.mean(tail[:, 5]))
    CD_wake_std = float(np.std(tail[:, 5]))

    CD_geo_avg = float(np.mean(tail[:, 6]))
    CS_geo_avg = float(np.mean(tail[:, 7]))
    CL_geo_avg = float(np.mean(tail[:, 8]))

    wall_runtime = time.time() - start_wall

    np.savez_compressed(
        FIELDS_NPZ,
        xg=xg, yg=yg, zg=zg,
        u=u, v=v, w=w, p=p,
        nu_t=nu_t,
        body=body,
        boundary_likelihood=boundary_likelihood,
        corner_likelihood=corner_likelihood,
        wake_likelihood_base=wake_likelihood_base,
        wake_likelihood=wake_likelihood,
        recursive_euler_wake_eddy_count=np.asarray([wake_analysis["eddy_count"]], dtype=np.int32),
        recursive_euler_wake_importance=np.asarray([wake_analysis["importance_score"]], dtype=np.float64),
        dns_like_mode=np.asarray([int(USE_DNS_LIKE_MODE)], dtype=np.int32),
        dns_like_re_l=np.asarray([RE_L], dtype=np.float64),
        dns_init_eddy_count=np.asarray([dns_init_metrics.get("eddy_count_used", 0)], dtype=np.int32),
        dns_init_max_du=np.asarray([dns_init_metrics.get("max_du", 0.0)], dtype=np.float64),
        dns_init_max_dv=np.asarray([dns_init_metrics.get("max_dv", 0.0)], dtype=np.float64),
        dns_init_max_dw=np.asarray([dns_init_metrics.get("max_dw", 0.0)], dtype=np.float64),
        dns_init_div_before=np.asarray([dns_init_metrics.get("div_before_projection", 0.0)], dtype=np.float64),
        dns_init_div_after=np.asarray([dns_init_metrics.get("div_after_projection", 0.0)], dtype=np.float64),
    )

    write_readable_3d_history(history)
    make_force_readable_plot(history)
    make_plots(history, xg, yg, zg, u, v, w, p, nu_t, body, wake_likelihood)

    summary = []
    summary.append("=== AHMED GEODESIC HYPERBOLIC SECTIONAL CFD SUMMARY ===")
    summary.append(f"Run mode                    : {RUN_MODE}")
    summary.append(f"Geometry source             : {geometry_source}")
