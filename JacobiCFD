def make_body_mask_from_sections(xg, yg, zg, section_x, section_polys):
    nx, ny, nz = len(xg), len(yg), len(zg)
    body = np.zeros((nx, ny, nz), dtype=bool)

    Y, Z = np.meshgrid(yg, zg, indexing="ij")

    for ix, x in enumerate(xg):
        if x < section_x[0] or x > section_x[-1]:
            continue

        j = int(np.argmin(np.abs(section_x - x)))
        poly = section_polys[j]

        inside_yz = points_in_polygon_yz(Y, Z, poly)
        body[ix, :, :] = inside_yz

    return body


def compute_voxel_metrics(body_mask, xg, yg, zg):
    wx = cell_widths(xg)
    wy = cell_widths(yg)
    wz = cell_widths(zg)

    vol = wx[:, None, None] * wy[None, :, None] * wz[None, None, :]
    masked_vol = np.where(body_mask, vol, 0.0)
    V = float(np.sum(masked_vol))

    idx = np.argwhere(body_mask)
    n = len(idx)

    if n == 0 or V <= 0.0:
        return dict(volume=0.0, xcg=0.0, ycg=0.0, zcg=0.0, cells=0)

    xcg = float(np.sum(masked_vol * xg[:, None, None]) / V)
    ycg = float(np.sum(masked_vol * yg[None, :, None]) / V)
    zcg = float(np.sum(masked_vol * zg[None, None, :]) / V)

    return dict(volume=V, xcg=xcg, ycg=ycg, zcg=zcg, cells=int(n))


