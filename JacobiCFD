def _arg_value(name, default=None):
    """Tiny CLI helper so run mode can be chosen before CFG is built."""
    if name in sys.argv:
        i = sys.argv.index(name)
        if i + 1 < len(sys.argv):
            return sys.argv[i + 1]
    prefix = name + "="
    for a in sys.argv[1:]:
        if a.startswith(prefix):
            return a.split("=", 1)[1]
    return default

