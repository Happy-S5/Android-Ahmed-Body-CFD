def resample_field_2d_to_uniform(field2d, axis_a, axis_b, a_new, b_new):
    """
    Bilinear interpolation from a nonuniform tensor grid to a uniform grid.

    Matplotlib streamplot works best on uniformly spaced axes, while this solver
    uses tanh/sech2 nonuniform clustering. This helper keeps the solver grid
    unchanged and only resamples visualization slices.

    field2d shape must be (len(axis_a), len(axis_b)).
    """
    field2d = np.asarray(field2d, dtype=float)
    tmp = np.empty((len(a_new), len(axis_b)), dtype=float)

    for j in range(len(axis_b)):
        tmp[:, j] = np.interp(a_new, axis_a, field2d[:, j])

    out = np.empty((len(a_new), len(b_new)), dtype=float)
    for i in range(len(a_new)):
        out[i, :] = np.interp(b_new, axis_b, tmp[i, :])

    return out


def make_streamline_plot(xg, yg, zg, u, v, w, body, wake_likelihood):
    """
    Save a dedicated streamline visualization.

    Panel 1: side-view x-z streamlines at y = 0.
    Panel 2: top-view x-y streamlines at z near mid body height.

    This is a visualization/diagnostic plot. It does not alter the CFD solve.
    """
    nxp = min(240, max(90, len(xg) * 2))
    nyp = min(160, max(70, len(yg) * 2))
    nzp = min(150, max(70, len(zg) * 2))

    xu = np.linspace(float(xg[0]), float(xg[-1]), nxp)
    yu = np.linspace(float(yg[0]), float(yg[-1]), nyp)
    zu = np.linspace(float(zg[0]), float(zg[-1]), nzp)

    iy = int(np.argmin(np.abs(yg - 0.0)))
    iz_mid = int(np.argmin(np.abs(zg - 0.50 * BODY_H)))

    # Side view: x-z at centerline y.
    Uxz = resample_field_2d_to_uniform(u[:, iy, :], xg, zg, xu, zu)
    Wxz = resample_field_2d_to_uniform(w[:, iy, :], xg, zg, xu, zu)
    Bxz = resample_field_2d_to_uniform(body[:, iy, :].astype(float), xg, zg, xu, zu)
    WLik_xz = resample_field_2d_to_uniform(wake_likelihood[:, iy, :], xg, zg, xu, zu)
    speed_xz = np.sqrt(Uxz * Uxz + Wxz * Wxz)

    mask_xz = Bxz > 0.45
    Uxz_m = np.ma.array(Uxz.T, mask=mask_xz.T)
    Wxz_m = np.ma.array(Wxz.T, mask=mask_xz.T)
    speed_xz_m = np.ma.array(speed_xz.T, mask=mask_xz.T)

    # Top view: x-y at mid body height.
    Uxy = resample_field_2d_to_uniform(u[:, :, iz_mid], xg, yg, xu, yu)
    Vxy = resample_field_2d_to_uniform(v[:, :, iz_mid], xg, yg, xu, yu)
    Bxy = resample_field_2d_to_uniform(body[:, :, iz_mid].astype(float), xg, yg, xu, yu)
    WLik_xy = resample_field_2d_to_uniform(wake_likelihood[:, :, iz_mid], xg, yg, xu, yu)
    speed_xy = np.sqrt(Uxy * Uxy + Vxy * Vxy)

    mask_xy = Bxy > 0.45
    Uxy_m = np.ma.array(Uxy.T, mask=mask_xy.T)
    Vxy_m = np.ma.array(Vxy.T, mask=mask_xy.T)
    speed_xy_m = np.ma.array(speed_xy.T, mask=mask_xy.T)

    fig, axes = plt.subplots(2, 1, figsize=(14, 10))

    ax = axes[0]
    cf0 = ax.contourf(xu, zu, WLik_xz.T, levels=32, alpha=0.68)
    ax.streamplot(xu, zu, Uxz_m, Wxz_m, color=speed_xz_m, density=1.45, linewidth=0.65, arrowsize=0.75)
    ax.contour(xu, zu, Bxz.T, levels=[0.5], colors="k", linewidths=1.2)
    ax.axvline(BODY_X1, color="k", linewidth=0.8, linestyle="--", alpha=0.55)
    ax.set_title("Side-view streamlines at y = 0, colored by speed over wake likelihood")
    ax.set_xlabel("x / streamwise coordinate")
    ax.set_ylabel("z / height")
    ax.set_xlim(float(xg[0]), float(xg[-1]))
    ax.set_ylim(float(zg[0]), float(min(zg[-1], max(1.05 * BODY_H, 0.60))))
    fig.colorbar(cf0, ax=ax, label="wake likelihood")

    ax = axes[1]
    cf1 = ax.contourf(xu, yu, WLik_xy.T, levels=32, alpha=0.68)
    ax.streamplot(xu, yu, Uxy_m, Vxy_m, color=speed_xy_m, density=1.45, linewidth=0.65, arrowsize=0.75)
    ax.contour(xu, yu, Bxy.T, levels=[0.5], colors="k", linewidths=1.2)
    ax.axvline(BODY_X1, color="k", linewidth=0.8, linestyle="--", alpha=0.55)
    ax.set_title(f"Top-view streamlines at z = {float(zg[iz_mid]):.4f} m")
    ax.set_xlabel("x / streamwise coordinate")
    ax.set_ylabel("y / lateral coordinate")
    ax.set_xlim(float(xg[0]), float(xg[-1]))
    ax.set_ylim(-0.85 * BODY_W, 0.85 * BODY_W)
    fig.colorbar(cf1, ax=ax, label="wake likelihood")

    fig.suptitle("DNS-like Ahmed-body streamline diagnostics", fontsize=14)
    fig.tight_layout(rect=[0, 0, 1, 0.97])
    fig.savefig(STREAMLINE_PNG, dpi=180)
    plt.close(fig)


def write_readable_3d_history(history):
    """Write a readable force-history table for the 3D solver."""
    if history is None or len(history) == 0:
        return
    h = np.asarray(history, dtype=float)
    tail = h[int(0.65 * len(h)):]
    lines = []
    lines.append("Ahmed 3D OBJ-only CD/CL force history")
    lines.append("=======================================")
    lines.append("")
    lines.append(f"Run mode                 : {RUN_MODE}")
    lines.append(f"Rows                     : {len(h)}")
    lines.append(f"History CSV              : {HISTORY_CSV}")
    lines.append(f"Tail-average CD_wake     : {np.mean(tail[:,5]):.9f}")
    lines.append(f"Tail-average CD_geoP     : {np.mean(tail[:,6]):.9f}")
    lines.append(f"Tail-average CL_geoP     : {np.mean(tail[:,8]):.9f}")
    lines.append(f"Tail-average div_l2      : {np.mean(tail[:,4]):.9e}")
    lines.append("")
    lines.append("Important: CD_geoP/CL_geoP are signed pressure-force diagnostics from the geodesic boundary triangles.")
    lines.append("CD_wake is a wake-momentum drag diagnostic. Use the 3D workstation mode or OpenFOAM/SU2 for validation.")
    lines.append("")
    header = f"{'step':>7s} {'time':>12s} {'dt':>10s} {'CFL':>7s} {'div_l2':>12s} {'CD_wake':>10s} {'CD_geoP':>10s} {'CL_geoP':>10s} {'u_max':>10s}"
    lines.append(header)
    lines.append('-' * len(header))
    # first 20, middle marker, last 20
    idxs = list(range(min(20, len(h))))
    if len(h) > 45:
        idxs += [-1]
    idxs += list(range(max(20, len(h)-20), len(h)))
    seen = set()
    for idx in idxs:
        if idx == -1:
            lines.append("   ... rows omitted; see CSV for every step ...")
            continue
        if idx in seen or idx < 0 or idx >= len(h):
            continue
        seen.add(idx)
        r = h[idx]
        lines.append(f"{int(r[0]):7d} {r[1]:12.5e} {r[2]:10.3e} {r[3]:7.3f} {r[4]:12.4e} {r[5]:10.5f} {r[6]:10.5f} {r[8]:10.5f} {r[10]:10.4f}")
    HISTORY_READABLE_TXT.write_text("\n".join(lines), encoding="utf-8")


def make_force_readable_plot(history):
    """Single clean CD/CL plot for the 3D solver."""
    if history is None or len(history) == 0:
