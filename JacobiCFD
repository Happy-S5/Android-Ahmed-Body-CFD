def apply_recursive_euler_dns_initial_perturbation(u, v, w, eddies, xg, yg, zg, body_mask):
    """
    DNS-like use of recursive Euler eddies.

    This is a one-time, small, approximately divergence-free perturbation in
    the y-z wake plane. It seeds instability, then the physical-viscosity
    Navier-Stokes projection update must evolve or dissipate the structures.

    It is not re-applied every step and it is not a force model.
    """
    metrics = {
        "enabled": bool(USE_DNS_LIKE_MODE and USE_DNS_INITIAL_EULER_PERTURBATION),
        "eddy_count_used": 0,
        "epsilon_fraction": float(DNS_PERTURBATION_EPSILON),
        "max_du": 0.0,
        "max_dv": 0.0,
        "max_dw": 0.0,
        "l2_before_projection": 0.0,
        "div_before_projection": 0.0,
        "div_after_projection": 0.0,
        "note": "disabled",
    }

    if not metrics["enabled"] or not eddies:
        return u, v, w, metrics

    selected = sorted(eddies, key=lambda e: e.get("amplitude", 0.0), reverse=True)
    selected = selected[:min(DNS_MAX_PERTURBATION_EDDIES, len(selected))]

    xg = np.asarray(xg, dtype=float)
    yg = np.asarray(yg, dtype=float)
    zg = np.asarray(zg, dtype=float)

    X = xg[:, None, None]
    Y = yg[None, :, None]
    Z = zg[None, None, :]

    du = np.zeros_like(u)
    dv = np.zeros_like(v)
    dw = np.zeros_like(w)

    eps_vel = DNS_PERTURBATION_EPSILON * U_INF
    L_decay = max(0.75 * BODY_L, 1.0e-12)

    for e in selected:
        cx, cy, cz = e["center"]
        radius = max(float(e["radius"]), 2.0 * min_grid_spacing(xg, yg, zg))
        amp = float(e.get("amplitude", 0.1))
        chirality = float(e.get("chirality", 1.0))
        phase = float(e.get("phase", 0.0))

        dx = X - cx
        dy = Y - cy
        dz = Z - cz
        r2 = dy * dy + dz * dz
        core2 = max(radius * radius, 1.0e-12)

        # Downstream-localized streamfunction amplitude.
        stream_env = np.exp(-r2 / (2.0 * core2)) * np.exp(-np.maximum(dx, 0.0) / L_decay)
        stream_env *= (dx > -0.25 * radius)

        # Mild Euler phase modulation along x; this creates a wake wave seed.
        theta = EULER_WAKE_PHASE_GAIN * dx / max(BODY_L, 1.0e-12) + phase
        wave = 0.5 + 0.5 * np.cos(theta)
        psi = chirality * eps_vel * amp * stream_env * wave

        # y-z divergence-free perturbation from streamfunction psi:
        #   v = d psi / dz, w = - d psi / dy approximately for Gaussian core.
        # The signs produce counter-rotating child eddies without changing u much.
        dv += -psi * dz / core2
        dw +=  psi * dy / core2

    # Clip the one-time perturbation so it remains a seed, not a forced solution.
    clip_vel = max(DNS_PERTURBATION_EPSILON * U_INF, 1.0e-12)
    du = np.clip(du, -clip_vel, clip_vel)
    dv = np.clip(dv, -clip_vel, clip_vel)
    dw = np.clip(dw, -clip_vel, clip_vel)

    if body_mask is not None:
        du[body_mask] = 0.0
        dv[body_mask] = 0.0
        dw[body_mask] = 0.0

    u2 = u + du
    v2 = v + dv
    w2 = w + dw

    metrics.update({
        "eddy_count_used": int(len(selected)),
        "max_du": float(np.max(np.abs(du))),
        "max_dv": float(np.max(np.abs(dv))),
        "max_dw": float(np.max(np.abs(dw))),
        "l2_before_projection": float(np.sqrt(np.mean((du*du + dv*dv + dw*dw)[~body_mask]))) if body_mask is not None else float(np.sqrt(np.mean(du*du + dv*dv + dw*dw))),
        "note": "one-time Euler recursive wake perturbation; not a recurring force",
    })

    return u2, v2, w2, metrics


