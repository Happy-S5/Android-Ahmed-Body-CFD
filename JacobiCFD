def make_plots(history, xg, yg, zg, u, v, w, p, nu_t, body, wake_likelihood):
    if history is None or len(history) == 0:
        return

    steps = history[:, 0]
    div_l2 = history[:, 4]
    cd_wake = history[:, 5]
    cd_geo = history[:, 6]
    cl_geo = history[:, 8]
    cfl = history[:, 3]
    nut_mean = history[:, 11]

    plt.figure(figsize=(12, 8))

    ax1 = plt.subplot(2, 2, 1)
    ax1.plot(steps, div_l2)
    ax1.set_title("Divergence residual")
    ax1.set_xlabel("step")
    ax1.set_ylabel("L2 div")

    ax2 = plt.subplot(2, 2, 2)
    ax2.plot(steps, cd_wake, label="CD wake")
    ax2.plot(steps, cd_geo, label="CD geodesic pressure")
    ax2.plot(steps, cl_geo, label="CL geodesic pressure")
    ax2.set_title("Force coefficients")
    ax2.set_xlabel("step")
    ax2.legend()

    ax3 = plt.subplot(2, 2, 3)
    ax3.plot(steps, cfl)
    ax3.set_title("CFL")
    ax3.set_xlabel("step")

    ax4 = plt.subplot(2, 2, 4)
    ax4.plot(steps, nut_mean)
    ax4.set_title("Mean eddy viscosity")
    ax4.set_xlabel("step")

    plt.tight_layout()
    plt.savefig(CONV_PNG, dpi=180)
    plt.close()

    iy = len(yg) // 2
    speed = np.sqrt(u*u + v*v + w*w)
    cp = p / max(Q_INF, 1.0e-30)

    X, Z = np.meshgrid(xg, zg, indexing="ij")

    plt.figure(figsize=(14, 10))

    ax1 = plt.subplot(2, 2, 1)
    im1 = ax1.contourf(X, Z, speed[:, iy, :], levels=40)
    ax1.contour(X, Z, body[:, iy, :], levels=[0.5], colors="k", linewidths=1.0)
    ax1.set_title("Midspan speed")
    ax1.set_xlabel("x")
    ax1.set_ylabel("z")
    plt.colorbar(im1, ax=ax1)

    ax2 = plt.subplot(2, 2, 2)
    im2 = ax2.contourf(X, Z, cp[:, iy, :], levels=40)
    ax2.contour(X, Z, body[:, iy, :], levels=[0.5], colors="k", linewidths=1.0)
    ax2.set_title("Midspan Cp")
    ax2.set_xlabel("x")
    ax2.set_ylabel("z")
    plt.colorbar(im2, ax=ax2)

    ax3 = plt.subplot(2, 2, 3)
    im3 = ax3.contourf(X, Z, nu_t[:, iy, :], levels=40)
    ax3.contour(X, Z, body[:, iy, :], levels=[0.5], colors="k", linewidths=1.0)
    ax3.set_title("Midspan eddy viscosity")
    ax3.set_xlabel("x")
    ax3.set_ylabel("z")
    plt.colorbar(im3, ax=ax3)

    ax4 = plt.subplot(2, 2, 4)
    im4 = ax4.contourf(X, Z, wake_likelihood[:, iy, :], levels=40)
    ax4.contour(X, Z, body[:, iy, :], levels=[0.5], colors="k", linewidths=1.0)
    ax4.set_title("Geodesic wake likelihood")
    ax4.set_xlabel("x")
    ax4.set_ylabel("z")
    plt.colorbar(im4, ax=ax4)

    plt.tight_layout()
    plt.savefig(FIELD_PNG, dpi=180)
    plt.close()

    make_streamline_plot(xg, yg, zg, u, v, w, body, wake_likelihood)


