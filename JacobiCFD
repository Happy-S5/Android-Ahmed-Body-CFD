# 8. SECTIONAL METRICS
# ============================================================

def compute_sectional_metrics(section_x, section_polygons_yz):
    xs = np.asarray(section_x, dtype=float)
    areas = []
    cys = []
    czs = []

    for p in section_polygons_yz:
        A, cy, cz = polygon_area_centroid_yz(p)
        areas.append(A)
        cys.append(cy)
        czs.append(cz)

    areas = np.asarray(areas)
    cys = np.asarray(cys)
    czs = np.asarray(czs)

    dxs = np.diff(xs)
    vol_seg = 0.5 * (areas[:-1] + areas[1:]) * dxs
    x_mid = 0.5 * (xs[:-1] + xs[1:])
    cy_mid = 0.5 * (cys[:-1] + cys[1:])
    cz_mid = 0.5 * (czs[:-1] + czs[1:])

    V = float(np.sum(vol_seg))
    xcg = float(np.sum(x_mid * vol_seg) / max(V, 1.0e-30))
    ycg = float(np.sum(cy_mid * vol_seg) / max(V, 1.0e-30))
    zcg = float(np.sum(cz_mid * vol_seg) / max(V, 1.0e-30))

    return dict(
        volume=V,
        xcg=xcg,
        ycg=ycg,
        zcg=zcg,
        section_area=areas,
        section_cy=cys,
        section_cz=czs,
    )


# ============================================================
# 9. GEODESIC SWEPT-TRIANGLE BOUNDARY UPGRADE
# ============================================================

def resample_closed_polygon_by_arclength(poly, n_out):
    p = np.asarray(poly, dtype=float)

    if len(p) < 3:
        raise ValueError("Need at least 3 polygon vertices.")

    if np.linalg.norm(p[0] - p[-1]) < 1.0e-12:
        p = p[:-1]

    q = np.vstack([p, p[0]])
    seg = q[1:] - q[:-1]
    seg_len = np.sqrt(np.sum(seg * seg, axis=1))
    perimeter = float(np.sum(seg_len))

    if perimeter < 1.0e-15:
        raise ValueError("Degenerate polygon perimeter.")

    s_nodes = np.concatenate([[0.0], np.cumsum(seg_len)])
    s_targets = np.linspace(0.0, perimeter, n_out, endpoint=False)

    out = []
    j = 0
    for s in s_targets:
        while j < len(seg_len) - 1 and s > s_nodes[j + 1]:
            j += 1
        ds = max(seg_len[j], 1.0e-15)
        t = (s - s_nodes[j]) / ds
        out.append(q[j] * (1.0 - t) + q[j + 1] * t)

    return np.asarray(out, dtype=float)


def original_vertex_corner_weights(poly):
    p = np.asarray(poly, dtype=float)
    n = len(p)
    weights = np.zeros(n, dtype=float)

    for i in range(n):
        a = p[(i - 1) % n] - p[i]
        b = p[(i + 1) % n] - p[i]
        na = _safe_norm(a)
        nb = _safe_norm(b)
        c = np.clip(np.dot(a, b) / (na * nb), -1.0, 1.0)
        angle = math.acos(c)
        weights[i] = np.clip((math.pi - angle) / (0.75 * math.pi), 0.0, 1.0)

    return weights


def resampled_corner_weights(poly_original, poly_resampled):
    p0 = np.asarray(poly_original, dtype=float)
    pr = np.asarray(poly_resampled, dtype=float)
    cw0 = original_vertex_corner_weights(p0)

    q = np.vstack([p0, p0[0]])
    edge_len = np.sqrt(np.sum((q[1:] - q[:-1]) ** 2, axis=1))
    radius = max(float(np.mean(edge_len)) * 0.25, 1.0e-8)

    out = np.zeros(len(pr), dtype=float)
    for j, pt in enumerate(pr):
        d = np.sqrt(np.sum((p0 - pt) ** 2, axis=1))
        influence = np.exp(-(d / radius) ** 2)
        out[j] = float(np.max(cw0 * influence))

    return np.clip(out, 0.0, 1.0)


def triangle_area_normal(p0, p1, p2):
    v1 = p1 - p0
    v2 = p2 - p0
    cr = np.cross(v1, v2)
    mag = _safe_norm(cr)
    area = 0.5 * mag
    n = cr / mag
    return float(area), n


def build_swept_geodesic_boundary_triangles(section_x, section_polygons_yz,
                                             n_per_section=64):
    xs = np.asarray(section_x, dtype=float)
    polys = [np.asarray(p, dtype=float) for p in section_polygons_yz]
    ns = len(xs)

    if ns < 2:
        raise ValueError("Need at least two sectional stations.")

    loops = []
    loop_corner_w = []
    areas = []
    cys = []
    czs = []

    for poly in polys:
        A, cy, cz = polygon_area_centroid_yz(poly)
        loop = resample_closed_polygon_by_arclength(poly, n_per_section)
        cw = resampled_corner_weights(poly, loop)

        loops.append(loop)
        loop_corner_w.append(cw)
        areas.append(A)
        cys.append(cy)
        czs.append(cz)

    areas = np.asarray(areas)
    cys = np.asarray(cys)
    czs = np.asarray(czs)

    volume = float(np.sum(0.5 * (areas[:-1] + areas[1:]) * np.diff(xs)))

    tri_p0 = []
    tri_p1 = []
    tri_p2 = []
    tri_centroid = []
    tri_normal = []
    tri_area = []
    tri_corner = []
    tri_cap = []

    for i in range(ns - 1):
        x0 = xs[i]
        x1 = xs[i + 1]
        loop0 = loops[i]
        loop1 = loops[i + 1]
        cw0 = loop_corner_w[i]
        cw1 = loop_corner_w[i + 1]

        cy_mid = 0.5 * (cys[i] + cys[i + 1])
        cz_mid = 0.5 * (czs[i] + czs[i + 1])
        x_mid = 0.5 * (x0 + x1)
        body_center = np.array([x_mid, cy_mid, cz_mid], dtype=float)

        for j in range(n_per_section):
            j2 = (j + 1) % n_per_section

            a = np.array([x0, loop0[j, 0], loop0[j, 1]], dtype=float)
            b = np.array([x0, loop0[j2, 0], loop0[j2, 1]], dtype=float)
            c = np.array([x1, loop1[j2, 0], loop1[j2, 1]], dtype=float)
            d = np.array([x1, loop1[j, 0], loop1[j, 1]], dtype=float)

            candidates = [(a, d, c), (a, c, b)]

            for pp0, pp1, pp2 in candidates:
                ar, nn = triangle_area_normal(pp0, pp1, pp2)
                cc = (pp0 + pp1 + pp2) / 3.0

                outward = cc - body_center
                if np.dot(nn, outward) < 0.0:
                    pp1, pp2 = pp2.copy(), pp1.copy()
                    ar, nn = triangle_area_normal(pp0, pp1, pp2)
                    cc = (pp0 + pp1 + pp2) / 3.0

                cw_tri = max(cw0[j], cw0[j2], cw1[j], cw1[j2])

                tri_p0.append(pp0)
                tri_p1.append(pp1)
                tri_p2.append(pp2)
                tri_centroid.append(cc)
                tri_normal.append(nn)
                tri_area.append(ar)
                tri_corner.append(cw_tri)
                tri_cap.append(0)

    for cap_index, normal_sign in [(0, -1.0), (ns - 1, 1.0)]:
        x = xs[cap_index]
        loop = loops[cap_index]
        cw = loop_corner_w[cap_index]
        A, cy, cz = polygon_area_centroid_yz(loop)
        center = np.array([x, cy, cz], dtype=float)

        for j in range(n_per_section):
            j2 = (j + 1) % n_per_section
            a = np.array([x, loop[j, 0], loop[j, 1]], dtype=float)
            b = np.array([x, loop[j2, 0], loop[j2, 1]], dtype=float)

            if normal_sign < 0.0:
                pp0, pp1, pp2 = center, b, a
            else:
                pp0, pp1, pp2 = center, a, b

            ar, nn = triangle_area_normal(pp0, pp1, pp2)
            cc = (pp0 + pp1 + pp2) / 3.0

            target = np.array([normal_sign, 0.0, 0.0])
            if np.dot(nn, target) < 0.0:
                pp1, pp2 = pp2.copy(), pp1.copy()
                ar, nn = triangle_area_normal(pp0, pp1, pp2)
                cc = (pp0 + pp1 + pp2) / 3.0

            tri_p0.append(pp0)
            tri_p1.append(pp1)
            tri_p2.append(pp2)
            tri_centroid.append(cc)
            tri_normal.append(nn)
            tri_area.append(ar)
            tri_corner.append(max(cw[j], cw[j2]))
            tri_cap.append(1 if normal_sign < 0.0 else 2)

    tri_p0 = np.asarray(tri_p0)
    tri_p1 = np.asarray(tri_p1)
    tri_p2 = np.asarray(tri_p2)
    tri_centroid = np.asarray(tri_centroid)
    tri_normal = np.asarray(tri_normal)
    tri_area = np.asarray(tri_area)
    tri_corner = np.asarray(tri_corner)
    tri_cap = np.asarray(tri_cap)

    x_min = float(np.min(xs))
    x_max = float(np.max(xs))
    L_body = max(x_max - x_min, 1.0e-12)

    x_norm = (tri_centroid[:, 0] - x_min) / L_body
    rear_weight = smoothstep(0.58, 1.00, x_norm)
    downstream_normal = np.clip(tri_normal[:, 0], 0.0, 1.0)
    corner_weight = tri_corner

    rear_cap = (tri_cap == 2).astype(float)
    front_cap = (tri_cap == 1).astype(float)

    wake_seed = (
        0.50 * rear_weight
        + 0.35 * downstream_normal
        + 0.45 * corner_weight
        + 0.65 * rear_cap
        + 0.10 * front_cap
    )

    wake_seed = np.clip(wake_seed, 0.0, 1.0)

    return {
        "x": xs,
        "loops_yz": loops,
        "section_area": areas,
        "section_cy": cys,
        "section_cz": czs,
        "volume": volume,
        "p0": tri_p0,
        "p1": tri_p1,
        "p2": tri_p2,
        "centroid": tri_centroid,
        "normal": tri_normal,
        "area": tri_area,
        "corner_weight": corner_weight,
        "rear_weight": rear_weight,
        "wake_seed": wake_seed,
        "cap_flag": tri_cap,
        "body_x_min": x_min,
        "body_x_max": x_max,
        "body_L": L_body,
    }


def map_geodesic_boundary_to_grid(geo, xg, yg, zg, body_mask=None):
    nx = len(xg)
    ny = len(yg)
    nz = len(zg)

    boundary = np.zeros((nx, ny, nz), dtype=np.float32)
    corner = np.zeros((nx, ny, nz), dtype=np.float32)
    wake = np.zeros((nx, ny, nz), dtype=np.float32)

    cent = geo["centroid"]
    seed = geo["wake_seed"]
    cweight = geo["corner_weight"]
    x_min = geo["body_x_min"]
    x_max = geo["body_x_max"]
    L = geo["body_L"]

    for m in range(len(cent)):
        cx, cy, cz = cent[m]

        ix = int(np.argmin(np.abs(xg - cx)))
        iy = int(np.argmin(np.abs(yg - cy)))
        iz = int(np.argmin(np.abs(zg - cz)))

        rx_b = GEODESIC_BOUNDARY_RADIUS_CELLS
        rx_c = GEODESIC_CORNER_RADIUS_CELLS

        boundary[max(0, ix-rx_b):min(nx, ix+rx_b+1),
                 max(0, iy-rx_b):min(ny, iy+rx_b+1),
                 max(0, iz-rx_b):min(nz, iz+rx_b+1)] = 1.0

        if cweight[m] > 0.05:
            sub = corner[max(0, ix-rx_c):min(nx, ix+rx_c+1),
                         max(0, iy-rx_c):min(ny, iy+rx_c+1),
                         max(0, iz-rx_c):min(nz, iz+rx_c+1)]
            np.maximum(sub, float(cweight[m]), out=sub)

    order = np.argsort(seed)[::-1]
    order = order[:min(GEODESIC_MAX_WAKE_SEEDS, len(order))]

    X = xg[:, None, None]
    Y = yg[None, :, None]
    Z = zg[None, None, :]

    wake_x_end = x_max + GEODESIC_WAKE_LENGTH_BODY * L

    for m in order:
        if seed[m] <= 0.05:
            break

        cx, cy, cz = cent[m]

        if cx < x_min + 0.25 * L:
            continue

        dx = X - cx
        downstream = (dx > 0.0) & (X <= wake_x_end)

        spread = GEODESIC_WAKE_SPREAD0 + GEODESIC_WAKE_SPREAD_SLOPE * np.maximum(dx, 0.0)
        spread2 = np.maximum(spread * spread, 1.0e-10)

        radial2 = (Y - cy) ** 2 + (Z - cz) ** 2

        wk = (
            float(seed[m])
            * np.exp(-radial2 / (2.0 * spread2))
            * np.exp(-np.maximum(dx, 0.0) / max(GEODESIC_WAKE_DECAY_BODY * L, 1.0e-12))
        )

        wk = np.where(downstream, wk, 0.0)
        wake = np.maximum(wake, wk.astype(np.float32))

    if body_mask is not None:
        wake = np.where(body_mask, 0.0, wake)

    return boundary, corner, np.clip(wake, 0.0, 1.0)


# ============================================================
# 9B. RECURSIVE EULER WAKE-EDDY REFINEMENT
# ============================================================

def euler_unit(theta):
    """
    Euler identity in code:
        exp(i theta) = cos(theta) + i sin(theta)
    Returns a complex unit vector used for recursive eddy branching.
    """
    return np.exp(1j * theta)


def _nearest_axis_index(axis, value):
    return int(np.argmin(np.abs(np.asarray(axis) - float(value))))


def write_recursive_euler_wake_csv(path, eddies):
    with open(path, "w", newline="", encoding="utf-8") as f:
        w = csv.writer(f)
        w.writerow([
            "eddy_id", "parent_id", "root_seed", "depth",
            "cx", "cy", "cz", "radius", "amplitude",
            "phase", "theta_yz", "chirality"
        ])
        for e in eddies:
            w.writerow([
                e["id"], e["parent_id"], e["root_seed"], e["depth"],
                e["center"][0], e["center"][1], e["center"][2],
                e["radius"], e["amplitude"], e["phase"],
                e["theta_yz"], e["chirality"],
            ])


def recursive_euler_wake_eddy_refinement(base_wake, geo, xg, yg, zg, body_mask=None):
    """
    Refines the smooth geodesic wake-likelihood field with recursive eddies.

    What it does:
      1. Uses the strongest geodesic wake seeds near the rear body.
      2. Recursively spawns smaller child eddies downstream.
      3. Uses Euler's identity, exp(i theta), to rotate each child in the y-z plane.
      4. Adds bounded oscillatory eddy likelihood, then blends with the original wake.

    Important:
      This is a likelihood/closure refinement, not a DNS turbulence solver.
    """
    base = np.asarray(base_wake, dtype=np.float32)
    refined_add = np.zeros_like(base, dtype=np.float32)
    eddies = []

    if (not USE_RECURSIVE_EULER_WAKE_REFINEMENT) or geo is None or np.max(base) <= 1.0e-12:
        metrics = analyze_wake_likelihood_importance(base, base, body_mask, eddies)
        return base, eddies, metrics

    xg = np.asarray(xg, dtype=float)
    yg = np.asarray(yg, dtype=float)
    zg = np.asarray(zg, dtype=float)
    hmin_local = min_grid_spacing(xg, yg, zg)

    cent = np.asarray(geo["centroid"], dtype=float)
    normals = np.asarray(geo["normal"], dtype=float)
    seed = np.asarray(geo["wake_seed"], dtype=float)
    x_min = float(geo["body_x_min"])
    x_max = float(geo["body_x_max"])
    L = float(max(geo["body_L"], 1.0e-12))

    # Strongest rear/downstream-facing seeds become recursive eddy roots.
    eligible = np.where((seed > 0.08) & (cent[:, 0] > x_min + 0.55 * L))[0]
    if len(eligible) == 0:
        eligible = np.where(seed > 0.08)[0]
    order = eligible[np.argsort(seed[eligible])[::-1]] if len(eligible) else np.array([], dtype=int)
    order = order[:min(EULER_WAKE_MAX_ROOTS, len(order))]

    min_radius = max(EULER_WAKE_MIN_RADIUS_CELLS * hmin_local, 1.0e-5)
    base_radius = max(0.18 * BODY_W, 2.5 * hmin_local)
    branch_angle = math.radians(EULER_WAKE_BRANCH_ANGLE_DEG)

    def spawn(center, radius, amp, phase, theta_yz, depth, parent_id, root_seed, chirality):
        if len(eddies) >= EULER_WAKE_MAX_FIELD_EDDIES:
            return
        if depth > EULER_WAKE_MAX_DEPTH or radius < min_radius or amp < 0.012:
            return
        if center[0] < x_min or center[0] > x_max + GEODESIC_WAKE_LENGTH_BODY * L:
            return

        eddy_id = len(eddies)
        eddies.append({
            "id": eddy_id,
            "parent_id": parent_id,
            "root_seed": int(root_seed),
            "depth": int(depth),
            "center": np.asarray(center, dtype=float),
            "radius": float(radius),
            "amplitude": float(amp),
            "phase": float(phase),
            "theta_yz": float(theta_yz),
            "chirality": float(chirality),
        })

        if depth == EULER_WAKE_MAX_DEPTH:
            return

        for sign in (-1.0, 1.0):
            child_radius = radius * EULER_WAKE_RADIUS_SCALE
            child_amp = amp * (0.78 - 0.055 * depth)
            child_theta = theta_yz + sign * branch_angle + chirality * (0.35 + 0.10 * depth)

            # Euler rotation in the cross-plane: y+i z shift = r exp(i theta).
            yz_shift = child_radius * EULER_WAKE_DOWNSTREAM_STEP * euler_unit(child_theta)
            child_center = np.array([
                center[0] + EULER_WAKE_DOWNSTREAM_STEP * child_radius,
                center[1] + float(np.real(yz_shift)),
                center[2] + float(np.imag(yz_shift)),
            ], dtype=float)

            child_phase = phase + sign * 0.5 * math.pi + chirality * branch_angle
            child_chirality = -chirality * sign

            spawn(child_center, child_radius, child_amp, child_phase,
                  child_theta, depth + 1, eddy_id, root_seed, child_chirality)

    for root_count, m in enumerate(order):
        cx, cy, cz = cent[m]
        nvec = normals[m]

        # Place the root just downstream of the surface seed.
        sx = cx + 0.35 * base_radius + 0.12 * L * max(nvec[0], 0.0)
        sy = cy
        sz = cz

        # Use normal direction where possible; otherwise split upper/lower branches.
        theta_yz = math.atan2(nvec[2], nvec[1] + 1.0e-30)
        if abs(nvec[1]) + abs(nvec[2]) < 1.0e-8:
            theta_yz = (1.0 if (root_count % 2 == 0) else -1.0) * 0.5 * math.pi

        local_radius = base_radius * (0.65 + 0.80 * float(seed[m]))
        amp = EULER_WAKE_AMPLITUDE_SCALE * float(seed[m])
        phase = root_count * 0.61803398875 * 2.0 * math.pi
        chirality = 1.0 if (root_count % 2 == 0) else -1.0

        spawn(np.array([sx, sy, sz], dtype=float), local_radius, amp,
              phase, theta_yz, 0, -1, int(m), chirality)

    # Deposit all recursive eddies onto the 3D grid.
    X = xg[:, None, None]
    Y = yg[None, :, None]
    Z = zg[None, None, :]
    wake_x_end = x_max + GEODESIC_WAKE_LENGTH_BODY * L

    for e in eddies:
        cx, cy, cz = e["center"]
        r = max(e["radius"], min_radius)
        amp = e["amplitude"]
        phase = e["phase"]
        chirality = e["chirality"]

        dx = X - cx
        downstream = (dx >= -0.15 * r) & (X <= wake_x_end)
        radial2 = (Y - cy) ** 2 + (Z - cz) ** 2

        theta = np.arctan2(Z - cz, Y - cy + 1.0e-30)
        wave_phase = EULER_WAKE_PHASE_GAIN * dx / max(L, 1.0e-12) + chirality * theta + phase

        # Bounded Euler/cosine likelihood: never injects negative likelihood.
        oscillation = 0.55 + 0.45 * np.cos(wave_phase)
        core = np.exp(-radial2 / (2.0 * max(r * r, 1.0e-12)))
        downstream_decay = np.exp(-np.maximum(dx, 0.0) / max(GEODESIC_WAKE_DECAY_BODY * L, 1.0e-12))

        wk = amp * oscillation * core * downstream_decay
        wk = np.where(downstream, wk, 0.0)
        refined_add = np.maximum(refined_add, wk.astype(np.float32))

    if body_mask is not None:
        refined_add = np.where(body_mask, 0.0, refined_add)

    refined = np.maximum(base, EULER_WAKE_BLEND * refined_add + (1.0 - EULER_WAKE_BLEND) * base)
    refined = np.clip(refined, 0.0, 1.0).astype(np.float32)

    if body_mask is not None:
        refined = np.where(body_mask, 0.0, refined)

    metrics = analyze_wake_likelihood_importance(base, refined, body_mask, eddies)
    return refined, eddies, metrics


def analyze_wake_likelihood_importance(base_wake, refined_wake, body_mask, eddies):
    """Quantifies whether wake likelihood materially changes the model."""
    base = np.asarray(base_wake, dtype=float)
    refined = np.asarray(refined_wake, dtype=float)

    if body_mask is None:
        fluid = np.ones_like(base, dtype=bool)
    else:
        fluid = ~body_mask

    base_f = base[fluid]
    refined_f = refined[fluid]
    delta_f = np.maximum(refined_f - base_f, 0.0)

    base_mean = float(np.mean(base_f)) if base_f.size else 0.0
    base_max = float(np.max(base_f)) if base_f.size else 0.0
    refined_mean = float(np.mean(refined_f)) if refined_f.size else 0.0
    refined_max = float(np.max(refined_f)) if refined_f.size else 0.0
    delta_mean = float(np.mean(delta_f)) if delta_f.size else 0.0
    delta_max = float(np.max(delta_f)) if delta_f.size else 0.0

    base_active = float(np.mean(base_f > EULER_WAKE_ACTIVE_THRESHOLD)) if base_f.size else 0.0
    refined_active = float(np.mean(refined_f > EULER_WAKE_ACTIVE_THRESHOLD)) if refined_f.size else 0.0

    # This is the direct mean fractional reduction applied to nu_t where enabled.
    nut_reduction_mean = float(GEODESIC_WAKE_NUT_REDUCTION * refined_mean) if GEODESIC_WAKE_REDUCE_NUT else 0.0
    nut_reduction_max = float(GEODESIC_WAKE_NUT_REDUCTION * refined_max) if GEODESIC_WAKE_REDUCE_NUT else 0.0

    # Compact importance score for reporting. Thresholds are conservative for sparse 3D grids.
    importance_score = (
        0.35 * min(refined_max / 0.50, 1.0)
        + 0.25 * min(refined_active / 0.010, 1.0)
        + 0.25 * min(nut_reduction_max / 0.12, 1.0)
        + 0.15 * min((delta_mean / max(base_mean, 1.0e-12)) / 0.25, 1.0)
    )

    if importance_score >= 0.60:
        decision = "IMPORTANT"
    elif importance_score >= 0.35:
        decision = "MODERATELY IMPORTANT"
    else:
        decision = "WEAK / DIAGNOSTIC ONLY"

    return {
        "base_mean": base_mean,
        "base_max": base_max,
        "refined_mean": refined_mean,
        "refined_max": refined_max,
        "delta_mean": delta_mean,
        "delta_max": delta_max,
        "base_active_fraction": base_active,
        "refined_active_fraction": refined_active,
        "eddy_count": int(len(eddies)),
        "nut_reduction_mean": nut_reduction_mean,
        "nut_reduction_max": nut_reduction_max,
        "importance_score": float(importance_score),
        "decision": decision,
    }


