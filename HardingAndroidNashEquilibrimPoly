def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Harding morphed polygon voxel CFD diagnostic with all-y+ reporting.")
    parser.add_argument("--obj", type=str, default=None, help="OBJ path. Default searches for AhmedGeometry.obj.")
    parser.add_argument("--out-dir", type=str, default="/storage/emulated/0/Download/AhmedGeometry", help="Output directory.")
    parser.add_argument("--obj-name", type=str, default="AhmedGeometry.obj", help="Default OBJ filename to search.")
    parser.add_argument("--ground-clearance", type=float, default=0.030, help="Ground clearance in meters.")
    parser.add_argument("--morph-alpha", type=float, default=0.015, help="Normal morph displacement in meters.")
    parser.add_argument("--iterations", type=int, default=50, help="Transient monitor iterations.")
    parser.add_argument("--nx", type=int, default=96, help="Voxel x count.")
    parser.add_argument("--ny", type=int, default=48, help="Voxel y count.")
    parser.add_argument("--nz", type=int, default=56, help="Voxel z count.")
    parser.add_argument("--no-align", action="store_true", help="Disable Ahmed benchmark alignment.")
    return parser.parse_args()


def main() -> None:
    global RUN_STATUS_FILE
    args = parse_args()
    try:
        print("[RUN] Harding CFD script launched.", flush=True)
        export_directory = prepare_export_directory(args.out_dir)
        RUN_STATUS_FILE = os.path.join(export_directory, "CFD_RUN_STATUS.txt")
        cprint("=" * 58)
        cprint("[RUN] STARTED Harding Morphed Polygon Voxel CFD Diagnostic — All-y+ Combined")
        cprint(f"[RUN] Output directory: {export_directory}")
        cprint(f"[RUN] Live status file: {RUN_STATUS_FILE}")
        cprint("=" * 58)

        target_path = resolve_obj_path(args.obj_name, export_directory, explicit_path=args.obj)
        cprint("[RUN] Step 1/10: Loading geometry...")
        base_geometry = AhmedGeometry(file_path=target_path)
        base_geometry.load_obj()

        if not args.no_align:
            cprint("[RUN] Step 1B/10: Aligning OBJ to Ahmed benchmark dimensions...")
            base_geometry.align_to_benchmark_ahmed_body(
                target_length=1.044,
                target_width=0.389,
                target_height=0.288,
                auto_axes=True,
            )

        cprint("[RUN] Step 2/10: Adjusting ground clearance...")
        base_geometry.adjust_ground_clearance(target_clearance_m=args.ground_clearance)

        cprint("[RUN] Step 3/10: Applying normal morphing...")
        base_geometry.morph_geometry(alpha_displacement=args.morph_alpha)

        cprint("[RUN] Step 4/10: Comparing geometric states...")
        vol_expansion = base_geometry.compare_geometric_states()

        cprint("[RUN] Step 5/10: Initializing solver...")
        solver = ProprietaryCFDSolver(base_geometry)

        cprint("[RUN] Step 6/10: Running transient simulation...")
        solver.execute_simulation_run(iterations=args.iterations, expansion_pct=vol_expansion)

        cprint("[RUN] Step 7/10: Exporting text summaries...")
        solver.export_text_summary(export_dir=export_directory, expansion_pct=vol_expansion)
        solver.export_physics_of_flow(export_dir=export_directory, expansion_pct=vol_expansion)

        cprint("[RUN] Step 8/10: Exporting coefficient/residual/2D plots...")
        solver.generate_and_save_graphs(export_dir=export_directory)
        solver.generate_and_save_residual_plot(export_dir=export_directory)
        solver.generate_and_save_streamlines_2d(export_dir=export_directory)
        solver.generate_and_save_yplus_mask(export_dir=export_directory)

        cprint("[RUN] Step 9/10: Building voxel field and all-y+ diagnostics...")
        solver.build_full_voxel_flow_field(grid_shape=(args.nx, args.ny, args.nz))
        solver.export_voxel_field_summary(export_dir=export_directory)
        solver.generate_and_save_voxel_slice_plots(export_dir=export_directory)
        solver.generate_and_save_voxel_top_view_plots(export_dir=export_directory)
        solver.generate_and_save_commercial_yplus_wall_plots(export_dir=export_directory)
        solver.generate_and_save_voxel_histogram_plots(export_dir=export_directory)
        solver.export_all_yplus_summary(export_dir=export_directory)
        solver.generate_and_save_all_yplus_wall_maps(export_dir=export_directory)
        solver.generate_and_save_all_yplus_histograms(export_dir=export_directory)

        cprint("[RUN] Step 10/10: Rendering 3D streamlines and finalizing...")
        solver.generate_and_save_streamlines_3d(export_dir=export_directory)

        complete_flag = os.path.join(export_directory, "CFD_RUN_COMPLETE.flag")
        Path(complete_flag).write_text("CFD run completed successfully.\n", encoding="utf-8")
        cprint("=" * 58)
        cprint("[RUN] COMPLETE")
        cprint(f"[RUN] Completion flag: {complete_flag}")
        cprint("=" * 58)

    except Exception:
        cprint("\n[RUN] FAILED")
        cprint(traceback.format_exc())
        raise
    finally:
        try:
            export_directory = prepare_export_directory(args.out_dir)
            log_path = os.path.join(export_directory, "CFD_Console_Output.txt")
            Path(log_path).write_text("\n".join(console_log_data) + "\n", encoding="utf-8")
        except Exception:
            pass
        try:
            sys.stdout.flush()
            sys.stderr.flush()
        except Exception:
            pass


if __name__ == "__main__":
    main()
