@dataclass
class FluidConstants:
    rho: float = 1.225
    mu: float = 1.81e-5
    u_inf: float = 27.78
    a_ref: float = 0.112

    @property
    def nu(self) -> float:
        return self.mu / self.rho

    @property
    def q_inf(self) -> float:
        return 0.5 * self.rho * self.u_inf * self.u_inf


class ProprietaryCFDSolver:
    """Reduced-order morphed polygon voxel CFD diagnostic."""

    def __init__(self, geometry: AhmedGeometry, constants: Optional[FluidConstants] = None):
        self.geometry = geometry
        self.const = constants or FluidConstants()

        self.history_time: List[int] = []
        self.history_cd_raw: List[float] = []
        self.history_cd_morphed: List[float] = []
        self.history_cl: List[float] = []
        self.residual_continuity: List[float] = []
        self.residual_momentum: List[float] = []
        self.residual_pressure: List[float] = []

        self.final_cd_raw = 0.0
        self.final_cd_morphed = 0.0
        self.final_cl = 0.0
        self.final_pressure_drag_fraction = 0.82
        self.final_viscous_drag_fraction = 0.18

        self.freestream_vel = self.const.u_inf
        self.ref_area = self.const.a_ref
        self.air_density = self.const.rho
        self.air_dynamic_viscosity = self.const.mu
        self.air_kinematic_viscosity = self.const.nu
        self.dynamic_pressure = self.const.q_inf
        self.characteristic_length = 1.044
        self.reynolds_number = 0.0
        self.skin_friction_coefficient = 0.0
        self.friction_velocity = 0.0
        self.yplus_first_height_y1 = 0.0
        self.yplus_first_height_y30 = 0.0
        self.underbody_vel = 0.0
        self.underbody_yplus_mean = 0.0
        self.underbody_yplus_max = 0.0

        self.voxel_x: Optional[np.ndarray] = None
        self.voxel_y: Optional[np.ndarray] = None
        self.voxel_z: Optional[np.ndarray] = None
        self.voxel_u: Optional[np.ndarray] = None
        self.voxel_v: Optional[np.ndarray] = None
        self.voxel_w: Optional[np.ndarray] = None
        self.voxel_pressure: Optional[np.ndarray] = None
        self.voxel_velocity_magnitude: Optional[np.ndarray] = None
        self.voxel_solid_mask: Optional[np.ndarray] = None
        self.voxel_fluid_mask: Optional[np.ndarray] = None
        self.voxel_wall_distance: Optional[np.ndarray] = None
        self.voxel_y_plus_wall_distance: Optional[np.ndarray] = None
