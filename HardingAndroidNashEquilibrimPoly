    def generate_and_save_all_yplus_histograms(self, export_dir: str) -> str:
        if self.all_yplus_stats is None:
            self.compute_all_yplus_wall_diagnostics()
        path = os.path.join(export_dir, "CFD_All_YPlus_Histograms.png")
        histogram_items: List[Tuple[str, np.ndarray]] = []
        if self.voxel_y_plus_wall_distance is not None:
            histogram_items.append(("Global Cf field", _finite_values(self.voxel_y_plus_wall_distance, mask=self.voxel_fluid_mask)))
        if self.voxel_y_plus_commercial is not None:
            histogram_items.append(("Commercial local field", _finite_values(self.voxel_y_plus_commercial, mask=self.voxel_fluid_mask)))
        for name, data in (self.all_yplus_surface_maps or {}).items():
            histogram_items.append((name.replace("_", " ").title(), _finite_values(data["values"], mask=data["mask"])))
        n = max(len(histogram_items), 1)
        rows = int(math.ceil(n / 2.0))
        fig, axes = plt.subplots(rows, 2, figsize=(15, max(6, rows * 3.2)))
        axes = np.ravel(axes)
        bins = np.linspace(0.0, 600.0, 80)
        for ax, (title, values) in zip(axes, histogram_items):
            values = np.asarray(values, dtype=np.float64)
            values = values[np.isfinite(values)]
            values = np.clip(values, 0.0, 600.0)
            if values.size > 0:
                ax.hist(values, bins=bins)
                ax.axvline(1.0, linestyle="--", linewidth=1.0)
                ax.axvline(30.0, linestyle="--", linewidth=1.0)
                ax.axvline(300.0, linestyle="--", linewidth=1.0)
            ax.set_title(title)
            ax.set_xlabel("y+")
            ax.set_ylabel("count")
        for ax in axes[len(histogram_items):]:
            ax.axis("off")
        fig.suptitle("All y+ Histograms", fontsize=18, fontweight="bold")
        fig.tight_layout(rect=[0, 0, 1, 0.96])
        fig.savefig(path, dpi=300)
        plt.close(fig)
        cprint(f"[EXPORT] All-y+ histograms saved to: {path}")
        return path

