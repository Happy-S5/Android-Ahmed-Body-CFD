class AhmedGeometry:
    """OBJ loader, benchmark alignment, normals, morphing, and ground clearance."""

    def __init__(self, file_path: str):
        self.file_path = file_path
        self.vertices: Optional[np.ndarray] = None
        self.faces: Optional[np.ndarray] = None
        self.vertex_normals: Optional[np.ndarray] = None
        self.face_areas: Optional[np.ndarray] = None
        self.loaded_vertices: Optional[np.ndarray] = None
        self.clearance_reference_vertices: Optional[np.ndarray] = None
        self.baseline_vertices: Optional[np.ndarray] = None
        self.num_cells = 0
        self.ground_clearance = 0.050
        self.benchmark_length = 1.044
        self.benchmark_width = 0.389
        self.benchmark_height = 0.288
        self.benchmark_aligned = False
        self.alignment_axis_order: Optional[Tuple[int, int, int]] = None
        self.alignment_scale: Optional[Tuple[float, float, float]] = None

    def load_obj(self) -> None:
        cprint("[I/O] Accessing internal storage...")
        vertices: List[List[float]] = []
        faces: List[List[int]] = []

        if not os.path.exists(self.file_path):
            cprint(f"[WARNING] File not found at {self.file_path}. Generating safe mock Ahmed body mesh.")
            self._generate_mock_mesh()
        else:
            try:
                with open(self.file_path, "r", encoding="utf-8", errors="ignore") as file:
                    for raw_line in file:
                        line = raw_line.strip()
                        if line.startswith("v "):
                            parts = line.split()[1:4]
                            if len(parts) == 3:
                                vertices.append([float(x) for x in parts])
                        elif line.startswith("f "):
                            raw = line.split()[1:]
                            indices = []
                            for item in raw:
                                idx = item.split("/")[0]
                                if idx:
                                    indices.append(int(idx) - 1)
                            if len(indices) >= 3:
                                # Fan triangulation supports quads/ngons.
                                for k in range(1, len(indices) - 1):
                                    faces.append([indices[0], indices[k], indices[k + 1]])

                if not vertices or not faces:
                    cprint("[WARNING] OBJ contained no usable vertices/faces. Generating mock mesh.")
                    self._generate_mock_mesh()
                else:
                    self.vertices = np.asarray(vertices, dtype=float)
                    self.faces = np.asarray(faces, dtype=int)
                    self.num_cells = int(len(self.faces))
            except (PermissionError, OSError, ValueError) as exc:
                cprint(f"[ERROR] Could not load OBJ: {exc}")
                cprint("[WARNING] Generating mock mesh instead.")
                self._generate_mock_mesh()

        self.loaded_vertices = np.copy(self.vertices)
        self.baseline_vertices = np.copy(self.vertices)
        self.calculate_normals_and_areas()
        cprint(f"[I/O] Successfully loaded {self.num_cells:,} structural cells.")

    def _generate_mock_mesh(self) -> None:
        length, width, height = self.benchmark_length, self.benchmark_width, self.benchmark_height
        x0, x1 = 0.0, length
        y0, y1 = -width / 2.0, width / 2.0
        z0, z1 = 0.0, height
        self.vertices = np.array(
            [
                [x0, y0, z0], [x1, y0, z0], [x1, y1, z0], [x0, y1, z0],
                [x0, y0, z1], [x1, y0, z1], [x1, y1, z1], [x0, y1, z1],
            ],
            dtype=float,
        )
        self.faces = np.array(
            [
                [0, 1, 2], [0, 2, 3],
                [4, 6, 5], [4, 7, 6],
                [0, 5, 1], [0, 4, 5],
                [3, 2, 6], [3, 6, 7],
                [1, 5, 6], [1, 6, 2],
                [0, 3, 7], [0, 7, 4],
            ],
            dtype=int,
        )
        self.num_cells = int(len(self.faces))

    @staticmethod
    def _permutation_parity(axis_order: Iterable[int]) -> int:
        axis_order = list(axis_order)
        inversions = 0
        for i in range(len(axis_order)):
            for j in range(i + 1, len(axis_order)):
                if axis_order[i] > axis_order[j]:
                    inversions += 1
        return inversions % 2

    def align_to_benchmark_ahmed_body(
        self,
        target_length: float = 1.044,
        target_width: float = 0.389,
        target_height: float = 0.288,
        auto_axes: bool = True,
    ) -> None:
        if self.vertices is None or len(self.vertices) == 0:
            return
        original_vertices = np.asarray(self.vertices, dtype=float)
        original_min = np.min(original_vertices, axis=0)
        original_max = np.max(original_vertices, axis=0)
        original_extents = original_max - original_min
        if np.any(original_extents <= 1.0e-12):
            cprint("[ALIGN] Degenerate OBJ extents detected. Skipping benchmark alignment.")
            return

        if auto_axes:
            sorted_axes = list(np.argsort(original_extents)[::-1])
            axis_order = [int(sorted_axes[0]), int(sorted_axes[1]), int(sorted_axes[2])]
        else:
            axis_order = [0, 1, 2]

        reordered = original_vertices[:, axis_order]
        reordered_min = np.min(reordered, axis=0)
        reordered_extents = np.max(reordered, axis=0) - reordered_min
        target_extents = np.array([target_length, target_width, target_height], dtype=float)
        scale = target_extents / np.maximum(reordered_extents, 1.0e-12)
        aligned = (reordered - reordered_min) * scale

        if self._permutation_parity(axis_order) == 1:
            aligned[:, 1] = target_width - aligned[:, 1]

        aligned[:, 0] = aligned[:, 0] - np.min(aligned[:, 0])
        aligned[:, 1] = aligned[:, 1] - 0.5 * (np.min(aligned[:, 1]) + np.max(aligned[:, 1]))
        aligned[:, 2] = aligned[:, 2] - np.min(aligned[:, 2])

        self.vertices = aligned
        self.benchmark_length = float(target_length)
        self.benchmark_width = float(target_width)
        self.benchmark_height = float(target_height)
        self.benchmark_aligned = True
        self.alignment_axis_order = tuple(axis_order)
        self.alignment_scale = tuple(float(x) for x in scale)
        self.loaded_vertices = np.copy(self.vertices)
        self.baseline_vertices = np.copy(self.vertices)
        self.calculate_normals_and_areas()

        dims = self.get_dimensions()
        cprint("[ALIGN] OBJ aligned to Ahmed benchmark frame")
        cprint(f"[ALIGN] Axis order source->x,y,z:     {self.alignment_axis_order}")
        cprint(f"[ALIGN] Scale factors:                {self.alignment_scale}")
        cprint(f"[ALIGN] Benchmark dimensions L,W,H:   {dims[0]:.4f} x {dims[1]:.4f} x {dims[2]:.4f} m")

    def calculate_normals_and_areas(self) -> None:
        if self.vertices is None or self.faces is None or len(self.faces) == 0:
            return
        v0 = self.vertices[self.faces[:, 0]]
        v1 = self.vertices[self.faces[:, 1]]
        v2 = self.vertices[self.faces[:, 2]]
        cross_products = np.cross(v1 - v0, v2 - v0)
        double_areas = np.linalg.norm(cross_products, axis=1)
        self.face_areas = 0.5 * double_areas
        face_normals = np.divide(
            cross_products,
            double_areas[:, np.newaxis] + 1.0e-12,
            out=np.zeros_like(cross_products),
            where=(double_areas[:, np.newaxis] != 0.0),
        )
        self.vertex_normals = np.zeros_like(self.vertices)
        for i in range(3):
            np.add.at(self.vertex_normals, self.faces[:, i], face_normals)
        norms = np.linalg.norm(self.vertex_normals, axis=1, keepdims=True)
        self.vertex_normals = np.divide(
            self.vertex_normals,
            norms,
            out=np.zeros_like(self.vertex_normals),
            where=(norms != 0.0),
        )

    def morph_geometry(self, alpha_displacement: float) -> None:
        cprint(f"[GEOMETRY] Applying normal-driven morphing alpha = {alpha_displacement:.4f} m")
        if self.vertices is not None and self.vertex_normals is not None:
            self.vertices = self.vertices + alpha_displacement * self.vertex_normals
            self.calculate_normals_and_areas()

    def adjust_ground_clearance(self, target_clearance_m: float) -> None:
        if self.vertices is None:
            return
        current_min_z = float(np.min(self.vertices[:, 2]))
        translation_z = target_clearance_m - current_min_z
        self.vertices[:, 2] = self.vertices[:, 2] + translation_z
        self.ground_clearance = float(target_clearance_m)
        self.calculate_normals_and_areas()
        self.clearance_reference_vertices = np.copy(self.vertices)
        cprint(f"[GEOMETRY] Underbody ground clearance adjusted to: {self.ground_clearance * 1000.0:.1f} mm")

    def get_total_surface_area(self) -> float:
        if self.face_areas is None:
            return 0.0
        return float(np.sum(self.face_areas))

    def get_bounding_box_volume(self) -> float:
        if self.vertices is None:
            return 0.0
        min_bounds = np.min(self.vertices, axis=0)
        max_bounds = np.max(self.vertices, axis=0)
        return float(np.prod(max_bounds - min_bounds))

    def get_dimensions(self) -> np.ndarray:
        if self.vertices is None:
            return np.array([self.benchmark_length, self.benchmark_width, self.benchmark_height], dtype=float)
        min_bounds = np.min(self.vertices, axis=0)
        max_bounds = np.max(self.vertices, axis=0)
        return max_bounds - min_bounds

    def body_box(self) -> Dict[str, float]:
        dims = self.get_dimensions()
        length = float(dims[0]) if dims[0] > 0 else self.benchmark_length
        width = float(dims[1]) if dims[1] > 0 else self.benchmark_width
        height = float(dims[2]) if dims[2] > 0 else self.benchmark_height
        return {
            "x0": 0.0,
            "x1": length,
            "y0": -0.5 * width,
            "y1": 0.5 * width,
            "z0": float(self.ground_clearance),
            "z1": float(self.ground_clearance + height),
            "length": length,
            "width": width,
            "height": height,
            "ground_clearance": float(self.ground_clearance),
        }

    def compare_geometric_states(self) -> float:
        cprint("\n" + "-" * 58)
        cprint(" GEOMETRIC MORPHING & UNDERBODY DIAGNOSTIC")
        cprint("-" * 58)
        current_vertices = np.copy(self.vertices)

        if self.clearance_reference_vertices is not None:
            self.vertices = np.copy(self.clearance_reference_vertices)
        elif self.baseline_vertices is not None:
            self.vertices = np.copy(self.baseline_vertices)
        self.calculate_normals_and_areas()
        ref_area = self.get_total_surface_area()
        ref_vol = self.get_bounding_box_volume()

        self.vertices = current_vertices
        self.calculate_normals_and_areas()
        morphed_area = self.get_total_surface_area()
        morphed_vol = self.get_bounding_box_volume()
        vol_expansion_pct = 100.0 * (morphed_vol - ref_vol) / max(ref_vol, 1.0e-30)

        cprint(f"Ground Clearance:        {self.ground_clearance * 1000.0:.1f} mm")
        cprint(f"Reference Surface Area:  {ref_area:.4f} m^2")
        cprint(f"Morphed Surface Area:    {morphed_area:.4f} m^2")
        cprint(f"Estimated Vol Expansion: {vol_expansion_pct:+.2f}%")
        cprint("-" * 58 + "\n")
        return float(vol_expansion_pct)


