    def build_full_voxel_flow_field(self, grid_shape: Tuple[int, int, int] = (96, 48, 56)) -> None:
        cprint("[VOXEL] Building full 3D voxel flow field...")
        nx, ny, nz = grid_shape
        box = self.geometry.body_box()
        domain = self._domain()
        x = np.linspace(domain["x_min"], domain["x_max"], nx)
        y = np.linspace(domain["y_min"], domain["y_max"], ny)
        z = np.linspace(domain["z_min"], domain["z_max"], nz)
        X, Y, Z = np.meshgrid(x, y, z, indexing="ij")
        self.voxel_x, self.voxel_y, self.voxel_z = X, Y, Z

        solid = (X >= box["x0"]) & (X <= box["x1"]) & (Y >= box["y0"]) & (Y <= box["y1"]) & (Z >= box["z0"]) & (Z <= box["z1"])
        fluid = ~solid
        self.voxel_solid_mask = solid
        self.voxel_fluid_mask = fluid

        U = np.ones_like(X, dtype=np.float32) * self.freestream_vel
        V = np.zeros_like(X, dtype=np.float32)
        Wv = np.zeros_like(X, dtype=np.float32)

        under = (X >= box["x0"]) & (X <= box["x1"]) & (Y >= box["y0"]) & (Y <= box["y1"]) & (Z < box["z0"])
        U[under] = self.underbody_vel

        dxwake = np.maximum(X - box["x1"], 0.0)
        zc = box["z0"] + 0.45 * box["height"]
        yc = 0.0
        wake_gauss = np.exp(-((dxwake - 0.35 * box["length"]) / (0.55 * box["length"] + 1e-6)) ** 2 - ((Y - yc) / (1.0 * box["width"] + 1e-6)) ** 2 - ((Z - zc) / (0.65 * box["height"] + 1e-6)) ** 2)
        wake = (X > box["x1"]) * wake_gauss
        U -= (1.05 * self.freestream_vel * wake).astype(np.float32)
        V += (0.28 * self.freestream_vel * wake * np.sin(2.0 * math.pi * (Y - domain["y_min"]) / (domain["y_max"] - domain["y_min"]))).astype(np.float32)
        Wv += (0.42 * self.freestream_vel * wake * np.sin(2.0 * math.pi * (Z - box["z0"]) / max(box["height"], 1e-6))).astype(np.float32)

        roof = (X >= box["x0"]) & (X <= box["x1"] + 0.25 * box["length"]) & (Z > box["z1"])
        U[roof] *= 1.02
        Wv[roof] += 0.02 * self.freestream_vel

        U[solid] = 0.0
        V[solid] = 0.0
        Wv[solid] = 0.0
        speed = np.sqrt(U * U + V * V + Wv * Wv)
        pressure = self.dynamic_pressure * (1.0 - (speed / max(self.freestream_vel, 1e-30)) ** 2)
        pressure[solid] = 0.0

        dist_ground = Z
        outside_x = np.maximum.reduce([box["x0"] - X, X - box["x1"], np.zeros_like(X)])
        outside_y = np.maximum.reduce([box["y0"] - Y, Y - box["y1"], np.zeros_like(Y)])
        outside_z = np.maximum.reduce([box["z0"] - Z, Z - box["z1"], np.zeros_like(Z)])
        dist_body = np.sqrt(outside_x**2 + outside_y**2 + outside_z**2)
        wall_distance = np.minimum(dist_ground, dist_body).astype(np.float32)
        wall_distance[solid] = 0.0

        self.voxel_u = U
        self.voxel_v = V
        self.voxel_w = Wv
        self.voxel_pressure = pressure.astype(np.float32)
        self.voxel_velocity_magnitude = speed.astype(np.float32)
        self.voxel_wall_distance = wall_distance
        self.voxel_wake_likelihood = wake.astype(np.float32)

        self.compute_all_yplus_wall_diagnostics()

        total_voxels = int(nx * ny * nz)
        dx = float(np.min(np.diff(x))) if nx > 1 else 0.0
        dy = float(np.min(np.diff(y))) if ny > 1 else 0.0
        dz = float(np.min(np.diff(z))) if nz > 1 else 0.0
        voxel_volume = abs(dx * dy * dz)
        fluid_volume = float(np.count_nonzero(fluid) * voxel_volume)
        under_volume = float(np.count_nonzero(under) * voxel_volume)
        wake_volume = float(np.count_nonzero(wake > 0.05) * voxel_volume)
        cprint("[VOXEL] Full voxel field created")
        cprint(f"[VOXEL] Grid shape x,y,z:              {nx} x {ny} x {nz}")
        cprint(f"[VOXEL] Total voxels:                 {total_voxels:,}")
        cprint(f"[VOXEL] Approximate field memory:     {speed.nbytes * 6 / 1024**2:.2f} MB")
        cprint(f"[VOXEL] Single voxel volume:          {voxel_volume:.6e} m^3")
        cprint(f"[VOXEL] Total fluid volume:           {fluid_volume:.6f} m^3")
        cprint(f"[VOXEL] Underbody voxel volume:       {under_volume:.6f} m^3")
        cprint(f"[VOXEL] Wake voxel volume:            {wake_volume:.6f} m^3")
        stats = self.all_yplus_stats or {}
        local = stats.get("commercial_local_wall_shear_field", {})
        global_stats = stats.get("global_cf_wall_distance_field", {})
        ground = stats.get("ground_plane", {})
        under_stats = stats.get("body_underside", {})
        cprint(f"[VOXEL] Commercial-style fluid y+ mean: {float(local.get('mean', 0.0)):.2f}")
        cprint(f"[VOXEL] Commercial-style fluid y+ max:  {float(local.get('max', 0.0)):.2f}")
        cprint(f"[VOXEL] Old global-Cf fluid y+ mean:    {float(global_stats.get('mean', 0.0)):.2f}")
        cprint(f"[VOXEL] Old global-Cf fluid y+ max:     {float(global_stats.get('max', 0.0)):.2f}")
        cprint(f"[VOXEL] First-layer ground y+ mean:     {float(ground.get('mean', 0.0)):.2f}")
        cprint(f"[VOXEL] First-layer ground y+ max:      {float(ground.get('max', 0.0)):.2f}")
        cprint(f"[VOXEL] First-layer underbody y+ mean:  {float(under_stats.get('mean', 0.0)):.2f}")
        cprint(f"[VOXEL] First-layer underbody y+ max:   {float(under_stats.get('max', 0.0)):.2f}")

    # --------------------------------------------------------
    # All-y+ diagnostics integrated from patch
    # --------------------------------------------------------

    def compute_all_yplus_wall_diagnostics(self) -> Dict[str, Dict[str, object]]:
        required = ["voxel_x", "voxel_y", "voxel_z", "voxel_velocity_magnitude"]
        for name in required:
            if getattr(self, name, None) is None:
                raise RuntimeError("Voxel field is not built yet. Run build_full_voxel_flow_field before all-y+ export.")

        X = self.voxel_x
        Y = self.voxel_y
        Z = self.voxel_z
        assert X is not None and Y is not None and Z is not None
        speed = np.asarray(self.voxel_velocity_magnitude, dtype=np.float64)
        solid = np.asarray(self.voxel_solid_mask, dtype=bool)
        fluid = np.asarray(self.voxel_fluid_mask, dtype=bool)
        wall_distance = np.asarray(self.voxel_wall_distance, dtype=np.float64)
        x = np.asarray(X[:, 0, 0], dtype=np.float64)
        y = np.asarray(Y[0, :, 0], dtype=np.float64)
        z = np.asarray(Z[0, 0, :], dtype=np.float64)
        rho, mu, nu = self.air_density, self.air_dynamic_viscosity, self.air_kinematic_viscosity
        box = self.geometry.body_box()
        dx = float(np.min(np.diff(x))) if len(x) > 1 else 1e-3
        dy = float(np.min(np.diff(y))) if len(y) > 1 else 1e-3
        dz = float(np.min(np.diff(z))) if len(z) > 1 else 1e-3
        min_grad_dist = 0.5 * min(abs(dx), abs(dy), abs(dz))

        if self.friction_velocity <= 0.0:
            self.compute_yplus_diagnostics()
        yplus_global = (self.friction_velocity * wall_distance / max(nu, 1.0e-30)).astype(np.float32)
        yplus_global[solid] = 0.0
        gradient_distance = np.maximum(wall_distance, min_grad_dist)
        tau_w_local = (mu * speed / np.maximum(gradient_distance, 1.0e-12)).astype(np.float32)
        tau_w_local[solid] = 0.0
        u_tau_local = np.sqrt(np.maximum(tau_w_local, 0.0) / max(rho, 1.0e-30)).astype(np.float32)
        yplus_local = (u_tau_local * wall_distance / max(nu, 1.0e-30)).astype(np.float32)
        yplus_local[solid] = 0.0
        self.voxel_y_plus_wall_distance = yplus_global
        self.voxel_y_plus_commercial = yplus_local
        self.voxel_y_plus = yplus_local
        self.voxel_wall_shear_stress = tau_w_local
        self.voxel_friction_velocity_local = u_tau_local

        X2, Y2 = np.meshgrid(x, y, indexing="ij")
        footprint_xy = (X2 >= box["x0"]) & (X2 <= box["x1"]) & (Y2 >= box["y0"]) & (Y2 <= box["y1"])
        XZ, ZZ = np.meshgrid(x, z, indexing="ij")
        side_xz_mask = (XZ >= box["x0"]) & (XZ <= box["x1"]) & (ZZ >= box["z0"]) & (ZZ <= box["z1"])
        YY, ZZ2 = np.meshgrid(y, z, indexing="ij")
        end_yz_mask = (YY >= box["y0"]) & (YY <= box["y1"]) & (ZZ2 >= box["z0"]) & (ZZ2 <= box["z1"])

        iz_ground = _nearest_index_above(z, 0.0)
        y1_ground = max(z[iz_ground], min_grad_dist)
        ground_map = _yplus_from_speed(speed[:, :, iz_ground], y1_ground, rho, mu, nu)
        ground_mask = fluid[:, :, iz_ground]

        iz_under = _nearest_index_below(z, box["z0"])
        y1_under = max(box["z0"] - z[iz_under], min_grad_dist)
        underside_map = _yplus_from_speed(speed[:, :, iz_under], y1_under, rho, mu, nu)
        underside_mask = footprint_xy & fluid[:, :, iz_under]

        iz_roof = _nearest_index_above(z, box["z1"])
        y1_roof = max(z[iz_roof] - box["z1"], min_grad_dist)
        roof_map = _yplus_from_speed(speed[:, :, iz_roof], y1_roof, rho, mu, nu)
        roof_mask = footprint_xy & fluid[:, :, iz_roof]

        iy_left = _nearest_index_below(y, box["y0"])
        y1_left = max(box["y0"] - y[iy_left], min_grad_dist)
        left_map = _yplus_from_speed(speed[:, iy_left, :], y1_left, rho, mu, nu)
        left_mask = side_xz_mask & fluid[:, iy_left, :]

        iy_right = _nearest_index_above(y, box["y1"])
        y1_right = max(y[iy_right] - box["y1"], min_grad_dist)
        right_map = _yplus_from_speed(speed[:, iy_right, :], y1_right, rho, mu, nu)
        right_mask = side_xz_mask & fluid[:, iy_right, :]

        ix_front = _nearest_index_below(x, box["x0"])
        y1_front = max(box["x0"] - x[ix_front], min_grad_dist)
        front_map = _yplus_from_speed(speed[ix_front, :, :], y1_front, rho, mu, nu)
        front_mask = end_yz_mask & fluid[ix_front, :, :]

        ix_rear = _nearest_index_above(x, box["x1"])
        y1_rear = max(x[ix_rear] - box["x1"], min_grad_dist)
        rear_map = _yplus_from_speed(speed[ix_rear, :, :], y1_rear, rho, mu, nu)
        rear_mask = end_yz_mask & fluid[ix_rear, :, :]

        self.all_yplus_surface_maps = {
            "ground_plane": {"values": ground_map, "mask": ground_mask, "first_cell_distance_m": float(y1_ground), "plane": "x-y", "extent": [float(x[0]), float(x[-1]), float(y[0]), float(y[-1])], "xlabel": "x length (m)", "ylabel": "y lateral (m)"},
            "body_underside": {"values": underside_map, "mask": underside_mask, "first_cell_distance_m": float(y1_under), "plane": "x-y", "extent": [float(x[0]), float(x[-1]), float(y[0]), float(y[-1])], "xlabel": "x length (m)", "ylabel": "y lateral (m)"},
            "body_roof_top": {"values": roof_map, "mask": roof_mask, "first_cell_distance_m": float(y1_roof), "plane": "x-y", "extent": [float(x[0]), float(x[-1]), float(y[0]), float(y[-1])], "xlabel": "x length (m)", "ylabel": "y lateral (m)"},
            "body_left_side": {"values": left_map, "mask": left_mask, "first_cell_distance_m": float(y1_left), "plane": "x-z", "extent": [float(x[0]), float(x[-1]), float(z[0]), float(z[-1])], "xlabel": "x length (m)", "ylabel": "z height (m)"},
            "body_right_side": {"values": right_map, "mask": right_mask, "first_cell_distance_m": float(y1_right), "plane": "x-z", "extent": [float(x[0]), float(x[-1]), float(z[0]), float(z[-1])], "xlabel": "x length (m)", "ylabel": "z height (m)"},
            "body_front_nose": {"values": front_map, "mask": front_mask, "first_cell_distance_m": float(y1_front), "plane": "y-z", "extent": [float(y[0]), float(y[-1]), float(z[0]), float(z[-1])], "xlabel": "y lateral (m)", "ylabel": "z height (m)"},
            "body_rear_base": {"values": rear_map, "mask": rear_mask, "first_cell_distance_m": float(y1_rear), "plane": "y-z", "extent": [float(y[0]), float(y[-1]), float(z[0]), float(z[-1])], "xlabel": "y lateral (m)", "ylabel": "z height (m)"},
        }
        stats: Dict[str, Dict[str, object]] = {
            "global_cf_wall_distance_field": _stats_from_values(yplus_global, mask=fluid),
            "commercial_local_wall_shear_field": _stats_from_values(yplus_local, mask=fluid),
        }
        for surface_name, surface_data in self.all_yplus_surface_maps.items():
            s = _stats_from_values(surface_data["values"], mask=surface_data["mask"])
            s["first_cell_distance_m"] = surface_data["first_cell_distance_m"]
            s["plane"] = surface_data["plane"]
            stats[surface_name] = s
        self.all_yplus_stats = stats
        return stats

    def export_all_yplus_summary(self, export_dir: str) -> Tuple[str, str]:
        if self.all_yplus_stats is None:
            self.compute_all_yplus_wall_diagnostics()
        assert self.all_yplus_stats is not None
        txt_path = os.path.join(export_dir, "CFD_All_YPlus_Summary.txt")
        csv_path = os.path.join(export_dir, "CFD_All_YPlus_Stats.csv")
        lines = [
            "=" * 70,
            "     ALL WALL-UNIT y+ DIAGNOSTIC SUMMARY",
            "=" * 70,
            "Method:",
            "  global_cf_wall_distance_field: y+ = u_tau_global y / nu.",
            "  commercial_local_wall_shear_field: tau_w ~= mu U_t / y_wall.",
            "  surface maps: first-cell wall y+ for each major wall/surface.",
            "",
            "Interpretation bands:",
            "  y+ <= 1       : wall-resolved viscous sublayer target.",
            "  y+ 1-5        : very fine / buffer onset.",
            "  y+ 5-30       : transition region; often awkward for wall functions.",
            "  y+ 30-100     : common wall-function region.",
            "  y+ 100-300    : coarse but often accepted for industrial wall functions.",
            "  y+ > 300      : too coarse for reliable wall shear / separation prediction.",
            "",
        ]
        for name, stats in self.all_yplus_stats.items():
            lines.append("-" * 70)
            lines.append(f"SURFACE/FIELD: {name}")
            lines.append(f"Quality                  : {stats.get('quality', 'UNKNOWN')}")
            if "plane" in stats:
                lines.append(f"Plane                    : {stats['plane']}")
            if "first_cell_distance_m" in stats:
                lines.append(f"First-cell distance      : {float(stats['first_cell_distance_m']):.9e} m")
            lines.append(f"Sample count             : {stats['count']}")
            lines.append(f"y+ min / mean / max      : {float(stats['min']):.3f} / {float(stats['mean']):.3f} / {float(stats['max']):.3f}")
            lines.append(f"y+ p05 / median / p95    : {float(stats['p05']):.3f} / {float(stats['median']):.3f} / {float(stats['p95']):.3f}")
            lines.append(f"y+ p99                  : {float(stats['p99']):.3f}")
            for band_name, _, _ in YPLUS_BANDS:
                frac = 100.0 * float(stats.get(band_name + "_fraction", 0.0))
                count = int(stats.get(band_name + "_count", 0))
                lines.append(f"{band_name:34s}: {frac:7.2f}%  ({count})")
        lines.append("=" * 70)
        Path(txt_path).write_text("\n".join(lines) + "\n", encoding="utf-8")

        fieldnames = ["name", "quality", "plane", "first_cell_distance_m", "count", "min", "mean", "median", "p05", "p25", "p75", "p95", "p99", "max"]
        for band_name, _, _ in YPLUS_BANDS:
            fieldnames += [band_name + "_fraction", band_name + "_count"]
        with open(csv_path, "w", encoding="utf-8", newline="") as handle:
            writer = csv.DictWriter(handle, fieldnames=fieldnames)
            writer.writeheader()
            for name, stats in self.all_yplus_stats.items():
                row = {"name": name}
                for field in fieldnames:
                    if field == "name":
                        continue
                    row[field] = stats.get(field, "")
                writer.writerow(row)
        cprint(f"[EXPORT] All-y+ summary saved to: {txt_path}")
        cprint(f"[EXPORT] All-y+ CSV saved to: {csv_path}")
        return txt_path, csv_path

    def generate_and_save_all_yplus_wall_maps(self, export_dir: str) -> str:
