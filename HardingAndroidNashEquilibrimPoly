    def generate_and_save_streamlines_3d(self, export_dir: str) -> str:
        cprint("[OUTPUT] Rendering 3D Streamline Kinematics...")
        box = self.geometry.body_box()
        domain = self._domain()
        fig = plt.figure(figsize=(13, 9))
        ax = fig.add_subplot(111, projection="3d")
        cmap = cm.get_cmap("jet")
        norm = Normalize(vmin=0, vmax=max(36.0, self.underbody_vel))
        segments = []
        colors = []
        y_seeds = np.linspace(domain["y_min"] * 0.85, domain["y_max"] * 0.85, 15)
        z_seeds = np.linspace(0.03, domain["z_max"] * 0.85, 12)
        for y0 in y_seeds:
            for z0 in z_seeds:
                if abs(y0) < 0.6 * box["width"] and box["z0"] < z0 < box["z1"]:
                    continue
                xs = np.linspace(domain["x_min"], domain["x_max"], 80)
                ys = np.ones_like(xs) * y0
                zs = np.ones_like(xs) * z0
                after = xs > box["x1"]
                decay = np.exp(-np.maximum(xs - box["x1"], 0) / (0.65 * box["length"]))
                ys = ys + after * 0.16 * box["width"] * np.sin(5.2 * (xs - box["x1"]) / box["length"] + y0) * decay
                zs = zs - after * 0.20 * box["height"] * np.sin(4.0 * (xs - box["x1"]) / box["length"] + z0) * decay
                under = (xs >= box["x0"]) & (xs <= box["x1"]) & (abs(ys) <= box["width"] / 2) & (zs < box["z0"])
                speed_line = np.ones_like(xs) * self.freestream_vel
                speed_line[under] = self.underbody_vel
                speed_line[after] *= 0.7 + 0.3 * decay[after]
                pts = np.column_stack([xs, ys, np.maximum(zs, 0.005)])
                for a, b, s in zip(pts[:-1], pts[1:], speed_line[:-1]):
                    segments.append([a, b])
                    colors.append(cmap(norm(float(s))))
        lc = Line3DCollection(segments, colors=colors, linewidths=1.3, alpha=0.9)
        ax.add_collection3d(lc)
        verts = np.array([
            [box["x0"], box["y0"], box["z0"]], [box["x1"], box["y0"], box["z0"]], [box["x1"], box["y1"], box["z0"]], [box["x0"], box["y1"], box["z0"]],
            [box["x0"], box["y0"], box["z1"]], [box["x1"], box["y0"], box["z1"]], [box["x1"], box["y1"], box["z1"]], [box["x0"], box["y1"], box["z1"]],
        ])
        faces = [[verts[i] for i in idx] for idx in ([0,1,2,3],[4,5,6,7],[0,1,5,4],[2,3,7,6],[1,2,6,5],[0,3,7,4])]
        poly = Poly3DCollection(faces, facecolors="darkgray", edgecolors="black", linewidths=0.8, alpha=0.85)
        ax.add_collection3d(poly)
        gx = np.array([domain["x_min"], domain["x_max"]])
        gy = np.array([domain["y_min"], domain["y_max"]])
        ground_x, ground_y = np.meshgrid(gx, gy)
        ground_z = np.zeros_like(ground_x)
        ax.plot_surface(ground_x, ground_y, ground_z, color="lightgray", alpha=0.35)
        sm = cm.ScalarMappable(norm=norm, cmap=cmap)
        sm.set_array([])
        cbar = fig.colorbar(sm, ax=ax, pad=0.1, shrink=0.7)
        cbar.set_label("Velocity Magnitude (m/s)")
        ax.set_title("3D Synthetic Streamlines: Underbody Acceleration and Rear Wake", fontsize=13, fontweight="bold")
        ax.set_xlabel("x length (m)")
        ax.set_ylabel("y lateral (m)")
        ax.set_zlabel("z height (m)")
        ax.set_xlim(domain["x_min"], domain["x_max"])
        ax.set_ylim(domain["y_min"], domain["y_max"])
        ax.set_zlim(domain["z_min"], domain["z_max"])
        ax.view_init(elev=23, azim=-58)
        fig.tight_layout()
        path = os.path.join(export_dir, "CFD_Streamlines_3D.png")
        fig.savefig(path, dpi=300)
        plt.close(fig)
        cprint(f"[EXPORT] 3D streamline profile saved to: {path}")
        return path


