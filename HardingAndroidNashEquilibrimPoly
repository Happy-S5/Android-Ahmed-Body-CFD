    def generate_and_save_voxel_top_view_plots(self, export_dir: str) -> str:
        cprint("[OUTPUT] Rendering voxel X-Y top-view wake plots...")
        assert self.voxel_x is not None and self.voxel_y is not None and self.voxel_velocity_magnitude is not None and self.voxel_wake_likelihood is not None
        box = self.geometry.body_box()
        iz = _nearest_index_above(self.voxel_z[0, 0, :], box["z0"] + 0.5 * box["height"])
        X = self.voxel_x[:, :, iz]
        Y = self.voxel_y[:, :, iz]
        speed = self.voxel_velocity_magnitude[:, :, iz]
        wake = self.voxel_wake_likelihood[:, :, iz]
        fig, axes = plt.subplots(1, 2, figsize=(14, 5))
        for ax, field, title in [(axes[0], speed, "Top View Speed"), (axes[1], wake, "Top View Wake Likelihood")]:
