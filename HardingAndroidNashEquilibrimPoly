YPLUS_BANDS = (
    ("viscous_sublayer_le_1", 0.0, 1.0),
    ("buffer_1_to_5", 1.0, 5.0),
    ("transition_5_to_30", 5.0, 30.0),
    ("wall_function_30_to_100", 30.0, 100.0),
    ("coarse_wall_function_100_to_300", 100.0, 300.0),
    ("too_coarse_gt_300", 300.0, np.inf),
)


def _finite_values(values: np.ndarray, mask: Optional[np.ndarray] = None) -> np.ndarray:
    arr = np.asarray(values, dtype=np.float64)
    finite = np.isfinite(arr)
    if mask is not None:
        finite = finite & np.asarray(mask, dtype=bool)
    return arr[finite]


def _safe_percentile(values: np.ndarray, q: float) -> float:
    if values.size == 0:
        return 0.0
    return float(np.percentile(values, q))


def _stats_from_values(values: np.ndarray, mask: Optional[np.ndarray] = None) -> Dict[str, object]:
    vals = _finite_values(values, mask=mask)
    total = int(vals.size)
    if total == 0:
        stats: Dict[str, object] = {
            "count": 0,
            "min": 0.0,
            "mean": 0.0,
            "median": 0.0,
            "p05": 0.0,
            "p25": 0.0,
            "p75": 0.0,
            "p95": 0.0,
            "p99": 0.0,
            "max": 0.0,
        }
    else:
        stats = {
            "count": total,
            "min": float(np.min(vals)),
            "mean": float(np.mean(vals)),
            "median": float(np.median(vals)),
            "p05": _safe_percentile(vals, 5),
            "p25": _safe_percentile(vals, 25),
            "p75": _safe_percentile(vals, 75),
            "p95": _safe_percentile(vals, 95),
            "p99": _safe_percentile(vals, 99),
            "max": float(np.max(vals)),
        }

    for name, lower, upper in YPLUS_BANDS:
        if total == 0:
            stats[name + "_count"] = 0
            stats[name + "_fraction"] = 0.0
            continue
        if np.isinf(upper):
            band = vals > lower
        else:
            band = (vals > lower) & (vals <= upper)
        count = int(np.count_nonzero(band))
        stats[name + "_count"] = count
        stats[name + "_fraction"] = float(count / total)

    mean_y = float(stats["mean"])
    max_y = float(stats["max"])
    if total == 0:
        quality = "NO_DATA"
    elif max_y <= 5.0:
        quality = "WALL_RESOLVED_OR_VERY_FINE"
    elif 30.0 <= mean_y <= 300.0 and max_y <= 600.0:
        quality = "WALL_FUNCTION_REASONABLE"
    elif mean_y <= 300.0 and max_y <= 1000.0:
        quality = "MARGINAL_WALL_FUNCTION"
    else:
        quality = "TOO_COARSE_FOR_RELIABLE_WALL_SHEAR"
    stats["quality"] = quality
    return stats


def _nearest_index_above(axis: np.ndarray, value: float) -> int:
    axis = np.asarray(axis)
    candidates = np.where(axis > value)[0]
    if candidates.size == 0:
        return int(len(axis) - 1)
    return int(candidates[0])


def _nearest_index_below(axis: np.ndarray, value: float) -> int:
    axis = np.asarray(axis)
    candidates = np.where(axis < value)[0]
    if candidates.size == 0:
        return 0
    return int(candidates[-1])


def _yplus_from_speed(speed: np.ndarray, first_cell_distance: float, rho: float, mu: float, nu: float) -> np.ndarray:
    y1 = float(max(abs(first_cell_distance), 1.0e-12))
    speed = np.asarray(speed, dtype=np.float64)
    tau_w = mu * np.maximum(speed, 0.0) / y1
    u_tau = np.sqrt(np.maximum(tau_w, 0.0) / max(rho, 1.0e-30))
    return (u_tau * y1 / max(nu, 1.0e-30)).astype(np.float32)


