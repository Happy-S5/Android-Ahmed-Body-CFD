console_log_data: List[str] = []
RUN_STATUS_FILE: Optional[str] = None
RUN_START_TIME = time.time()


def update_run_status(message: str) -> None:
    global RUN_STATUS_FILE
    elapsed = time.time() - RUN_START_TIME
    status_line = f"[{elapsed:8.2f} s] {message}"
    if RUN_STATUS_FILE is not None:
        try:
            with open(RUN_STATUS_FILE, "w", encoding="utf-8") as status_file:
                status_file.write(status_line + "\n")
                status_file.write("Script is still running if this file keeps updating.\n")
        except OSError:
            pass


def cprint(message: object) -> None:
    msg = str(message)
    print(msg, flush=True)
    sys.stdout.flush()
    console_log_data.append(msg)
    update_run_status(msg)


def prepare_export_directory(preferred_directory: str) -> str:
    try:
        os.makedirs(preferred_directory, exist_ok=True)
        test_file = os.path.join(preferred_directory, "_write_test.tmp")
        with open(test_file, "w", encoding="utf-8") as handle:
            handle.write("test")
        os.remove(test_file)
        return preferred_directory
    except OSError:
        fallback = os.getcwd()
        print(
            f"[WARNING] Could not write to {preferred_directory}. "
            f"Using fallback directory: {fallback}",
            flush=True,
        )
        return fallback


def is_readable_file(file_path: str) -> bool:
    try:
        if not os.path.isfile(file_path):
            return False
        with open(file_path, "r", encoding="utf-8", errors="ignore") as test_file:
            test_file.read(1)
        return True
    except (OSError, PermissionError):
        return False


def resolve_obj_path(file_name: str, export_directory: str, explicit_path: Optional[str] = None) -> str:
    if explicit_path:
        explicit = os.path.abspath(os.path.expanduser(explicit_path))
        if is_readable_file(explicit):
            cprint(f"[I/O] Using explicit readable OBJ: {explicit}")
            return explicit
        cprint(f"[WARNING] Explicit OBJ is not readable: {explicit}")

    try:
        script_directory = os.path.dirname(os.path.abspath(__file__))
    except NameError:
        script_directory = os.getcwd()

    candidate_paths = [
        os.path.join(os.getcwd(), file_name),
        os.path.join(script_directory, file_name),
        os.path.join(export_directory, file_name),
        os.path.join("/storage/emulated/0/Download", file_name),
        os.path.join("/storage/emulated/0/Download/AhmedGeometry", file_name),
        os.path.join("/storage/emulated/0/Documents", file_name),
        os.path.join("/storage/emulated/0/Documents/AhmedGeometry", file_name),
        os.path.join("/sdcard/Download", file_name),
        os.path.join("/sdcard/Download/AhmedGeometry", file_name),
        os.path.expanduser("~/storage/downloads/" + file_name),
        os.path.expanduser("~/storage/downloads/AhmedGeometry/" + file_name),
        os.path.expanduser("~/storage/documents/" + file_name),
        os.path.expanduser("~/storage/documents/AhmedGeometry/" + file_name),
    ]

    seen_paths = set()
    unique_candidate_paths = []
    for path in candidate_paths:
        normalized = os.path.abspath(os.path.expanduser(path))
        if normalized not in seen_paths:
            seen_paths.add(normalized)
            unique_candidate_paths.append(normalized)

    cprint("[I/O] Searching for readable OBJ file...")
    for path in unique_candidate_paths:
        cprint(f"[I/O] Checking: {path}")
        if is_readable_file(path):
            cprint(f"[I/O] Using readable OBJ: {path}")
            return path
        if os.path.exists(path):
            cprint(f"[I/O] Found but cannot read due to permission: {path}")

    fallback_path = os.path.join(os.getcwd(), file_name)
    cprint("[WARNING] No readable OBJ found. Solver will use mock geometry.")
    cprint(f"[WARNING] Fallback OBJ path: {fallback_path}")
    return fallback_path


