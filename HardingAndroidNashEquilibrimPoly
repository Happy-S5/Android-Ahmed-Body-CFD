    def _domain(self) -> Dict[str, float]:
        box = self.geometry.body_box()
        L, W, H, g = box["length"], box["width"], box["height"], box["ground_clearance"]
        return {
            "x_min": -0.30 * L,
            "x_max": 1.65 * L,
            "y_min": -3.0 * W,
            "y_max": 3.0 * W,
            "z_min": 0.0,
            "z_max": g + 2.4 * H,
            "L": L,
            "W": W,
            "H": H,
            "g": g,
        }

    def _centerline_xz_field(self, nx: int = 180, nz: int = 100) -> Tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
        box = self.geometry.body_box()
        domain = self._domain()
        x = np.linspace(domain["x_min"], domain["x_max"], nx)
        z = np.linspace(domain["z_min"] + 1e-5, domain["z_max"], nz)
        X, Z = np.meshgrid(x, z, indexing="ij")
        U = np.ones_like(X) * self.freestream_vel
        Wv = np.zeros_like(X)
        body = (X >= box["x0"]) & (X <= box["x1"]) & (Z >= box["z0"]) & (Z <= box["z1"])
        under = (X >= box["x0"]) & (X <= box["x1"]) & (Z < box["z0"])
        U[under] = self.underbody_vel

        wake = X > box["x1"]
        dx = np.maximum(X - box["x1"], 0.0)
        xscale = max(0.45 * box["length"], 1e-6)
        zc = box["z0"] + 0.42 * box["height"]
        r2 = ((dx - 0.35 * box["length"]) / xscale) ** 2 + ((Z - zc) / (0.55 * box["height"] + 1e-6)) ** 2
        recirc = np.exp(-r2) * wake
        U -= 1.25 * self.freestream_vel * recirc
        Wv += 0.75 * self.freestream_vel * recirc * ((X - box["x1"]) / (0.45 * box["length"] + 1e-6))
        Wv -= 0.85 * self.freestream_vel * recirc * ((Z - zc) / (0.40 * box["height"] + 1e-6))
        over = (X >= box["x0"]) & (X <= box["x1"] + 0.35 * box["length"]) & (Z > box["z1"])
        Wv[over] += 0.03 * self.freestream_vel
        U[body] = 0.0
        Wv[body] = 0.0
        speed = np.sqrt(U * U + Wv * Wv)
        return X, Z, U, Wv, speed

