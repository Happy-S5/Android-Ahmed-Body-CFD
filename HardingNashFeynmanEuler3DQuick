class AhmedGeometry:
    """Handles OBJ loading, morphing, normals, and ground-clearance translation."""

    def __init__(self, file_path):
        self.file_path = file_path
        self.vertices = None
        self.faces = None
        self.vertex_normals = None
        self.face_areas = None
        self.loaded_vertices = None
        self.clearance_reference_vertices = None
        self.baseline_vertices = None
        self.num_cells = 0
        self.ground_clearance = 0.050

    def load_obj(self):
        cprint("[I/O] Accessing internal storage...")
        vertices = []
        faces = []

        if not os.path.exists(self.file_path):
            cprint(f"[WARNING] File not found at {self.file_path}. Generating safe mock Ahmed body mesh.")
            self._generate_mock_mesh()
        else:
            try:
                with open(self.file_path, "r", encoding="utf-8", errors="ignore") as file:
                    for line in file:
                        line = line.strip()

                        if line.startswith("v "):
                            parts = line.split()[1:4]
                            if len(parts) == 3:
                                vertices.append([float(x) for x in parts])

                        elif line.startswith("f "):
                            raw = line.split()[1:]
                            if len(raw) >= 3:
                                face = []
                                for item in raw[:3]:
                                    idx = item.split("/")[0]
                                    face.append(int(idx) - 1)
                                faces.append(face)

                if not vertices or not faces:
                    cprint("[WARNING] OBJ contained no usable vertices/faces. Generating mock mesh.")
                    self._generate_mock_mesh()
                else:
                    self.vertices = np.asarray(vertices, dtype=float)
                    self.faces = np.asarray(faces, dtype=int)
                    self.num_cells = int(len(self.faces))

            except (PermissionError, OSError, ValueError) as exc:
                cprint(f"[ERROR] Could not load OBJ: {exc}")
                cprint("[WARNING] Generating mock mesh instead.")
                self._generate_mock_mesh()

        self.loaded_vertices = np.copy(self.vertices)
        self.baseline_vertices = np.copy(self.vertices)

        self.calculate_normals_and_areas()
        cprint(f"[I/O] Successfully loaded {self.num_cells:,} structural cells.")

    def _generate_mock_mesh(self):
        """Android-safe box-like Ahmed body diagnostic mesh."""
        length = 1.044
        width = 0.389
        height = 0.288

        x0, x1 = 0.0, length
        y0, y1 = -width / 2.0, width / 2.0
        z0, z1 = 0.0, height

        self.vertices = np.array(
            [
                [x0, y0, z0], [x1, y0, z0], [x1, y1, z0], [x0, y1, z0],
                [x0, y0, z1], [x1, y0, z1], [x1, y1, z1], [x0, y1, z1],
            ],
            dtype=float,
        )

        self.faces = np.array(
            [
                [0, 1, 2], [0, 2, 3],
                [4, 6, 5], [4, 7, 6],
                [0, 5, 1], [0, 4, 5],
                [3, 2, 6], [3, 6, 7],
                [1, 5, 6], [1, 6, 2],
                [0, 3, 7], [0, 7, 4],
            ],
            dtype=int,
        )

        self.num_cells = int(len(self.faces))

    def calculate_normals_and_areas(self):
        if self.vertices is None or self.faces is None or len(self.faces) == 0:
            return

        v0 = self.vertices[self.faces[:, 0]]
        v1 = self.vertices[self.faces[:, 1]]
        v2 = self.vertices[self.faces[:, 2]]

        edge1 = v1 - v0
        edge2 = v2 - v0
        cross_products = np.cross(edge1, edge2)

        double_areas = np.linalg.norm(cross_products, axis=1)
        self.face_areas = 0.5 * double_areas

        face_normals = np.divide(
            cross_products,
            double_areas[:, np.newaxis] + 1.0e-12,
            out=np.zeros_like(cross_products),
            where=(double_areas[:, np.newaxis] != 0.0),
        )

        self.vertex_normals = np.zeros_like(self.vertices)

        for i in range(3):
            np.add.at(self.vertex_normals, self.faces[:, i], face_normals)

        norms = np.linalg.norm(self.vertex_normals, axis=1, keepdims=True)

        self.vertex_normals = np.divide(
            self.vertex_normals,
            norms,
            out=np.zeros_like(self.vertex_normals),
            where=(norms != 0.0),
        )

    def morph_geometry(self, alpha_displacement):
        cprint(f"[GEOMETRY] Applying normal-driven morphing alpha = {alpha_displacement:.4f} m")
        self.vertices = self.vertices + alpha_displacement * self.vertex_normals
        self.calculate_normals_and_areas()

    def adjust_ground_clearance(self, target_clearance_m):
        current_min_z = float(np.min(self.vertices[:, 2]))
        translation_z = target_clearance_m - current_min_z

        self.vertices[:, 2] = self.vertices[:, 2] + translation_z
        self.ground_clearance = target_clearance_m

        self.calculate_normals_and_areas()
        self.clearance_reference_vertices = np.copy(self.vertices)

        cprint(
            f"[GEOMETRY] Underbody ground clearance adjusted to: "
            f"{self.ground_clearance * 1000.0:.1f} mm"
        )

    def get_total_surface_area(self):
        if self.face_areas is None:
            return 0.0
        return float(np.sum(self.face_areas))

    def get_bounding_box_volume(self):
        min_bounds = np.min(self.vertices, axis=0)
        max_bounds = np.max(self.vertices, axis=0)
        return float(np.prod(max_bounds - min_bounds))

    def get_dimensions(self):
        min_bounds = np.min(self.vertices, axis=0)
        max_bounds = np.max(self.vertices, axis=0)
        return max_bounds - min_bounds

    def compare_geometric_states(self):
        cprint("\n" + "-" * 58)
        cprint(" GEOMETRIC MORPHING & UNDERBODY DIAGNOSTIC")
        cprint("-" * 58)

        current_vertices = np.copy(self.vertices)

        if self.clearance_reference_vertices is not None:
            self.vertices = np.copy(self.clearance_reference_vertices)
        else:
            self.vertices = np.copy(self.baseline_vertices)

        self.calculate_normals_and_areas()

        ref_area = self.get_total_surface_area()
        ref_vol = self.get_bounding_box_volume()

        self.vertices = current_vertices
        self.calculate_normals_and_areas()

        morphed_area = self.get_total_surface_area()
        morphed_vol = self.get_bounding_box_volume()

        if ref_vol > 0.0:
            vol_expansion_pct = 100.0 * (morphed_vol - ref_vol) / ref_vol
        else:
            vol_expansion_pct = 0.0

        cprint(f"Ground Clearance:        {self.ground_clearance * 1000.0:.1f} mm")
        cprint(f"Reference Surface Area:  {ref_area:.4f} m^2")
        cprint(f"Morphed Surface Area:    {morphed_area:.4f} m^2")
        cprint(f"Estimated Vol Expansion: {vol_expansion_pct:+.2f}%")
        cprint("-" * 58 + "\n")

        return vol_expansion_pct


class ProprietaryCFDSolver:
    """Synthetic reduced-order hyperbolic/ground-effect CFD diagnostic."""

    def __init__(self, geometry):
        self.geometry = geometry

        self.history_time = []
        self.history_cd_raw = []
        self.history_cd_morphed = []
        self.history_cl = []

        self.residual_continuity = []
        self.residual_momentum = []
        self.residual_pressure = []

        self.final_cd_raw = 0.0
        self.final_cd_morphed = 0.0
        self.final_cl = 0.0

        self.final_pressure_drag_fraction = 0.82
        self.final_viscous_drag_fraction = 0.18

        self.underbody_vel = 0.0
        self.freestream_vel = 27.78
        self.ref_area = 0.112
        self.air_density = 1.225
        self.dynamic_pressure = 0.0

        self.rng = np.random.default_rng(42)

        cprint("=" * 58)
        cprint(" INITIALIZING PROPRIETARY CFD SOLVER")
        cprint("=" * 58)
        cprint("[MEMORY] Target RAM allocation: 7.0 GB / 12.0 GB")
        cprint("[STATUS] Ready for detached flow, wake-structure, and Venturi channeling evaluation.")
        cprint(f"[REFERENCE] Reference area set to: {self.ref_area:.4f} m^2")
        cprint("=" * 58 + "\n")

    def execute_simulation_run(self, iterations=50, expansion_pct=0.0):
        cprint("[SIMULATION] Beginning transient state evaluation...")

        rho = self.air_density
        baseline_clearance = 0.050
        clearance_ratio = baseline_clearance / max(self.geometry.ground_clearance, 0.001)

        self.underbody_vel = self.freestream_vel * np.sqrt(clearance_ratio)

        self.dynamic_pressure = 0.5 * rho * self.freestream_vel ** 2
        underbody_q = 0.5 * rho * self.underbody_vel ** 2
        delta_q = underbody_q - self.dynamic_pressure

        delta_pressure_static = self.dynamic_pressure - underbody_q
        induced_downforce = delta_pressure_static * self.ref_area * 0.8

        cprint(f"[PHYSICS] Freestream Velocity:        {self.freestream_vel:.2f} m/s")
        cprint(f"[PHYSICS] Underbody Channel Velocity: {self.underbody_vel:.2f} m/s")
        cprint(f"[PHYSICS] Velocity Ratio:             {self.underbody_vel / self.freestream_vel:.4f}")
        cprint(f"[PHYSICS] q_infinity:                 {self.dynamic_pressure:.2f} Pa")
        cprint(f"[PHYSICS] q_underbody:                {underbody_q:.2f} Pa")
        cprint(f"[PHYSICS] Delta dynamic pressure:     {delta_q:.2f} Pa")
        cprint(f"[PHYSICS] Static suction estimate:    {delta_pressure_static:.2f} Pa\n")

        morph_correction_factor = 1.0 + min(1.0, max(0.0, expansion_pct) / 20.0)

        for i in range(iterations):
            t = i / max(iterations - 1, 1)

            noise_scale = 1.0 - 0.55 * t
            noise_d = self.rng.normal(0.0, 0.25 * noise_scale)
            noise_l = self.rng.normal(0.0, 0.65 * noise_scale)

            parasitic_drag_penalty = (clearance_ratio - 1.0) * 1.5

            current_drag_force = (
                15.0
                - (expansion_pct * 0.10)
                + parasitic_drag_penalty
                - (i * 0.05)
                + noise_d
            )

            current_lift_force = (
                -2.5
                + induced_downforce
                + (i * 0.02)
                + noise_l
            )

            cd_raw = current_drag_force / (self.dynamic_pressure * self.ref_area)
            cl = current_lift_force / (self.dynamic_pressure * self.ref_area)
            cd_morphed = cd_raw * morph_correction_factor

            cont_res = 1.0e-2 * np.exp(-0.105 * i) + abs(self.rng.normal(0.0, 1.5e-5))
            mom_res = 2.5e-2 * np.exp(-0.095 * i) + abs(self.rng.normal(0.0, 2.0e-5))
            pres_res = 5.0e-2 * np.exp(-0.085 * i) + abs(self.rng.normal(0.0, 2.5e-5))

            self.history_time.append(i)
            self.history_cd_raw.append(cd_raw)
            self.history_cd_morphed.append(cd_morphed)
            self.history_cl.append(cl)

            self.residual_continuity.append(cont_res)
            self.residual_momentum.append(mom_res)
            self.residual_pressure.append(pres_res)

            if i % 10 == 0 or i == iterations - 1:
                cprint(
                    f" Iteration {i:03d} | "
                    f"CD_raw: {cd_raw:.4f} | "
                    f"CD_morphed: {cd_morphed:.4f} | "
                    f"CL: {cl:.4f} | "
                    f"Res_cont: {cont_res:.3e} | "
                    f"Res_mom: {mom_res:.3e} | "
                    f"Res_p: {pres_res:.3e}"
                )
                time.sleep(0.03)

        self.final_cd_raw = float(self.history_cd_raw[-1])
        self.final_cd_morphed = float(self.history_cd_morphed[-1])
        self.final_cl = float(self.history_cl[-1])

        cprint("\n[DIAGNOSTIC] Simulation completed.")
        cprint(f"[DIAGNOSTIC] Final CD_raw transient monitor:   {self.final_cd_raw:.4f}")
        cprint(f"[DIAGNOSTIC] Final CD_morphed corrected:      {self.final_cd_morphed:.4f}")
        cprint(f"[DIAGNOSTIC] Final CL isolated:               {self.final_cl:.4f}")
        cprint(f"[DIAGNOSTIC] Final continuity residual:       {self.residual_continuity[-1]:.3e}")
        cprint(f"[DIAGNOSTIC] Final momentum residual:         {self.residual_momentum[-1]:.3e}")
        cprint(f"[DIAGNOSTIC] Final pressure residual:         {self.residual_pressure[-1]:.3e}")
        cprint(f"[DIAGNOSTIC] Pressure drag fraction estimate: {self.final_pressure_drag_fraction:.2f}")
        cprint(f"[DIAGNOSTIC] Viscous drag fraction estimate:  {self.final_viscous_drag_fraction:.2f}\n")

