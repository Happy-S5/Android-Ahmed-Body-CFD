    def generate_and_save_streamlines_2d(self, export_dir):
        cprint("[OUTPUT] Rendering 2D X-Z Streamline Kinematics...")

        dims = self.geometry.get_dimensions()

        length = float(dims[0]) if dims[0] > 0 else 1.044
        height = float(dims[2]) if dims[2] > 0 else 0.288
        clearance = self.geometry.ground_clearance

        z_grid, x_grid = np.mgrid[0:height * 2.5:150j, -0.5:length * 2.0:220j]

        u = np.ones_like(x_grid) * self.freestream_vel
        w = np.zeros_like(x_grid)

        underbody_mask = (
            (x_grid >= 0.0)
            & (x_grid <= length)
            & (z_grid <= clearance)
        )

        u[underbody_mask] = self.underbody_vel

        wake_x_center = length + 0.15
        wake_z_center = clearance + height * 0.4

        wake_radius_sq = (
            (x_grid - wake_x_center) ** 2
            + (z_grid - wake_z_center) ** 2
            + 0.01
        )

        wake_mask = (
            (x_grid > length)
            & (x_grid < length + 0.8)
            & (z_grid > clearance)
        )

        u[wake_mask] = (
            u[wake_mask] * 0.30
            + 12.0
            * ((z_grid[wake_mask] - wake_z_center) / wake_radius_sq[wake_mask])
            * np.exp(-wake_radius_sq[wake_mask] / 0.1)
        )

        w[wake_mask] = (
            -12.0
            * ((x_grid[wake_mask] - wake_x_center) / wake_radius_sq[wake_mask])
            * np.exp(-wake_radius_sq[wake_mask] / 0.1)
        )

        w[z_grid <= 0.01] = 0.0

        fig, ax = plt.subplots(figsize=(12, 5))

        speed = np.sqrt(u ** 2 + w ** 2)

        strm = ax.streamplot(
            x_grid[0, :],
            z_grid[:, 0],
            u,
            w,
            color=speed,
            cmap="jet",
            linewidth=1.2,
            density=1.8,
            arrowsize=1.4,
        )

        fig.colorbar(strm.lines, ax=ax, label="Velocity Magnitude (m/s)")

        body_patch = patches.Rectangle(
            (0.0, clearance),
            length,
            height,
            linewidth=2,
            edgecolor="black",
            facecolor="darkgray",
            zorder=3,
        )

        ax.add_patch(body_patch)
        ax.axhline(0.0, color="black", linewidth=3)

        ax.set_xlim(-0.3, length * 1.8)
        ax.set_ylim(0.0, height * 2.0)

        ax.set_title(
            "X-Z Centerline Plane: Underbody Flow and Wake Separation",
            fontsize=14,
            fontweight="bold",
        )

        ax.set_xlabel("Length x (m)")
        ax.set_ylabel("Height z (m)")

        plt.tight_layout()

        stream_path = os.path.join(export_dir, "CFD_Streamline_Profile_2D_XZ.png")
        plt.savefig(stream_path, dpi=300)
        cprint(f"[EXPORT] 2D streamline profile saved to: {stream_path}")
        plt.close()

    def _velocity_field_3d(self, point, length, width, height, clearance):
        x, y, z = point

        inside_body = (
            0.0 <= x <= length
            and -width / 2.0 <= y <= width / 2.0
            and clearance <= z <= clearance + height
        )

        if inside_body:
            return np.array([0.0, 0.0, 0.0])

        u = self.freestream_vel
        v = 0.0
        w = 0.0

        if (
            0.0 <= x <= length
            and abs(y) <= width * 0.55
            and 0.0 <= z <= clearance
        ):
            u = self.underbody_vel

        xc = length + 0.20
        zc = clearance + 0.45 * height

        dx = x - xc
        dz = z - zc
        r2 = dx * dx + dz * dz + 0.015

        if x > length:
            swirl = 9.0 * np.exp(-r2 / 0.15)
            u += 0.45 * swirl * dz / r2
            u -= 0.55 * self.freestream_vel * np.exp(-r2 / 0.20)
            w += -0.45 * swirl * dx / r2

        vortex_centers = [
            (-0.35 * width, 1.0),
            (0.35 * width, -1.0),
        ]

        for yc, sign in vortex_centers:
            dy = y - yc
            dz2 = z - (clearance + 0.35 * height)
            r2v = dy * dy + dz2 * dz2 + 0.008

            if x > length:
                vortex = (
                    3.5
                    * np.exp(-((x - length) ** 2) / 0.55)
                    * np.exp(-r2v / 0.04)
                )

                v += sign * vortex * dz2 / r2v
                w += -sign * vortex * dy / r2v

        return np.array([u, v, w])

    def _integrate_streamline(
        self,
        seed,
        length,
        width,
        height,
        clearance,
        ds=0.015,
        steps=240,
    ):
        points = [np.array(seed, dtype=float)]

        for _ in range(steps):
            p = points[-1]

            if p[0] < -0.35 or p[0] > length * 1.95:
                break

            if abs(p[1]) > width * 1.8:
                break

            if p[2] < 0.0 or p[2] > height * 2.3:
                break

            vel = self._velocity_field_3d(p, length, width, height, clearance)
            speed = float(np.linalg.norm(vel))

            if speed < 1.0e-6:
                break

            points.append(p + ds * vel / speed)

        return np.array(points)

    def generate_and_save_streamlines_3d(self, export_dir):
        cprint("[OUTPUT] Rendering 3D Streamline Kinematics...")

        dims = self.geometry.get_dimensions()

        length = float(dims[0]) if dims[0] > 0 else 1.044
        width = float(dims[1]) if dims[1] > 0 else 0.389
        height = float(dims[2]) if dims[2] > 0 else 0.288
        clearance = self.geometry.ground_clearance

        seeds = []

        for y in np.linspace(-0.55 * width, 0.55 * width, 7):
            for z in np.linspace(clearance * 0.4, clearance + height * 1.65, 8):
                seeds.append([-0.25, y, z])

        for y in np.linspace(-0.45 * width, 0.45 * width, 7):
            seeds.append([-0.12, y, clearance * 0.5])

        streamlines = []
        speeds = []

        for seed in seeds:
            pts = self._integrate_streamline(seed, length, width, height, clearance)

            if len(pts) > 3:
                streamlines.append(pts)

                line_speeds = [
                    np.linalg.norm(
                        self._velocity_field_3d(
                            p,
                            length,
                            width,
                            height,
                            clearance,
                        )
                    )
                    for p in pts
                ]

                speeds.append(np.array(line_speeds))

        fig = plt.figure(figsize=(12, 8))
        ax = fig.add_subplot(111, projection="3d")

        if speeds:
            all_speeds = np.concatenate(speeds)
        else:
            all_speeds = np.array([0.0, self.freestream_vel])

        norm = Normalize(
            vmin=float(np.min(all_speeds)),
            vmax=float(np.max(all_speeds)),
        )

        cmap = plt.get_cmap("jet")

        for pts, spd in zip(streamlines, speeds):
            segs = np.stack([pts[:-1], pts[1:]], axis=1)
            colors = cmap(norm(spd[:-1]))

            lc = Line3DCollection(
                segs,
                colors=colors,
                linewidths=1.5,
                alpha=0.9,
            )

            ax.add_collection3d(lc)

        x0, x1 = 0.0, length
        y0, y1 = -width / 2.0, width / 2.0
        z0, z1 = clearance, clearance + height

        verts = np.array(
            [
                [x0, y0, z0],
                [x1, y0, z0],
                [x1, y1, z0],
                [x0, y1, z0],
                [x0, y0, z1],
                [x1, y0, z1],
                [x1, y1, z1],
                [x0, y1, z1],
            ]
        )

        body_faces = [
            [verts[i] for i in [0, 1, 2, 3]],
            [verts[i] for i in [4, 5, 6, 7]],
            [verts[i] for i in [0, 1, 5, 4]],
            [verts[i] for i in [2, 3, 7, 6]],
            [verts[i] for i in [1, 2, 6, 5]],
            [verts[i] for i in [0, 3, 7, 4]],
        ]

        poly = Poly3DCollection(
            body_faces,
            facecolors="darkgray",
            edgecolors="black",
            linewidths=0.8,
            alpha=0.85,
        )

        ax.add_collection3d(poly)

        gx = np.array([-0.3, length * 1.8])
        gy = np.array([-width * 1.25, width * 1.25])

        ground_x, ground_y = np.meshgrid(gx, gy)
        ground_z = np.zeros_like(ground_x)

        ax.plot_surface(
            ground_x,
            ground_y,
            ground_z,
            color="lightgray",
            alpha=0.35,
        )

        sm = cm.ScalarMappable(norm=norm, cmap=cmap)
        sm.set_array([])

        cbar = fig.colorbar(sm, ax=ax, pad=0.1, shrink=0.7)
        cbar.set_label("Velocity Magnitude (m/s)")

        ax.set_title(
            "3D Synthetic Streamlines: Underbody Acceleration and Rear Wake",
            fontsize=13,
            fontweight="bold",
        )

        ax.set_xlabel("x length (m)")
        ax.set_ylabel("y lateral (m)")
        ax.set_zlabel("z height (m)")

        ax.set_xlim(-0.3, length * 1.8)
        ax.set_ylim(-width * 1.2, width * 1.2)
        ax.set_zlim(0.0, height * 2.0)

        ax.view_init(elev=23, azim=-58)

        plt.tight_layout()

        stream3d_path = os.path.join(export_dir, "CFD_Streamlines_3D.png")
        plt.savefig(stream3d_path, dpi=300)
        cprint(f"[EXPORT] 3D streamline profile saved to: {stream3d_path}")
        plt.close()


def main():
    file_name = "AhmedGeometry.obj"
    export_directory = "/storage/emulated/0/Download/AhmedGeometry"

    android_download_path = os.path.join(export_directory, file_name)
    local_app_path = os.path.join(os.getcwd(), file_name)

    if os.path.exists(android_download_path):
        target_path = android_download_path
    else:
        target_path = local_app_path

    if not os.path.exists(export_directory):
        export_directory = os.getcwd()

    base_geometry = AhmedGeometry(file_path=target_path)
    base_geometry.load_obj()

    base_geometry.adjust_ground_clearance(target_clearance_m=0.030)

    base_geometry.morph_geometry(alpha_displacement=0.015)

    vol_expansion = base_geometry.compare_geometric_states()

    solver = ProprietaryCFDSolver(base_geometry)
    solver.execute_simulation_run(iterations=50, expansion_pct=vol_expansion)

    solver.export_text_summary(export_dir=export_directory, expansion_pct=vol_expansion)
    solver.export_physics_of_flow(export_dir=export_directory, expansion_pct=vol_expansion)
    solver.generate_and_save_graphs(export_dir=export_directory)
    solver.generate_and_save_residual_plot(export_dir=export_directory)
    solver.generate_and_save_streamlines_2d(export_dir=export_directory)
    solver.generate_and_save_streamlines_3d(export_dir=export_directory)
    solver.export_console_log(export_dir=export_directory)


if __name__ == "__main__":
    main()
